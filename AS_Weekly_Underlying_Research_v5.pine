//@version=6
strategy(
    title = "Ali Swing Suite: Weekly Underlying Research v5 - NOT OPTION PERFORMANCE",
    shorttitle = "AS Underlying Research v5",
    overlay = true,
    pyramiding = 0,
    initial_capital = 100000,
    commission_type = strategy.commission.percent,
    commission_value = 0.01,
    slippage = 1,
    process_orders_on_close = true,
    max_bars_back = 500
)

// This tester measures only the underlying proxy. It does not model option prices,
// spreads, Greeks, assignment, exercise, or Bullish Weekly Participation returns.

// config/strategy.yaml parity constants. Do not edit independently.
const int PARITY_SCHEMA_VERSION = 5
const int PARITY_TREND_MINIMUM = 80
const int PARITY_MARKET_MINIMUM = 70
const float PARITY_READY_DISTANCE_ATR = 0.30
const float PARITY_MAX_EXTENSION_ATR = 0.75
const int PARITY_MAX_CONFIRMED_AGE = 1

string GROUP_RESEARCH = "Underlying-proxy research"
int maximumHoldBars = input.int(5, "Maximum daily bars held", minval = 1, maxval = 5, group = GROUP_RESEARCH)
int noProgressBars = input.int(2, "No-progress reassessment bars", minval = 1, maxval = 3, group = GROUP_RESEARCH)
bool requireMarket = input.bool(true, "Require confirmed SPY/QQQ daily context", group = GROUP_RESEARCH)

bool completedBar = barstate.isconfirmed
float ema21 = ta.ema(close, 21)
float sma50 = ta.sma(close, 50)
float sma200 = ta.sma(close, 200)
float currentAtr = ta.atr(14)
float breakoutTrigger = ta.highest(high[1], 20)
float support = math.max(math.min(ema21, close), math.min(sma50, close))
float relativeVolume = volume / math.max(ta.sma(volume, 20), 1)

[weeklyClose, weeklyEma21] = request.security(
    syminfo.tickerid,
    "1W",
    [close[1], ta.ema(close, 21)[1]],
    lookahead = barmerge.lookahead_on
)
[spyClose, spySma50, spySma200] = request.security(
    "AMEX:SPY",
    "1D",
    [close[1], ta.sma(close, 50)[1], ta.sma(close, 200)[1]],
    lookahead = barmerge.lookahead_on
)
[qqqClose, qqqSma50, qqqSma200] = request.security(
    "NASDAQ:QQQ",
    "1D",
    [close[1], ta.sma(close, 50)[1], ta.sma(close, 200)[1]],
    lookahead = barmerge.lookahead_on
)

int trendScore = 0
trendScore += close > ema21 ? 15 : 0
trendScore += ema21 > sma50 ? 15 : 0
trendScore += close > sma50 ? 10 : 0
trendScore += sma50 > sma200 ? 20 : 0
trendScore += close > sma200 ? 15 : 0
trendScore += sma200 > sma200[10] ? 10 : 0
trendScore += weeklyClose > weeklyEma21 ? 15 : 0
bool spyPass = spyClose > spySma50 and spySma50 > spySma200
bool qqqPass = qqqClose > qqqSma50 and qqqSma50 > qqqSma200
int marketScore = (spyPass ? 50 : 0) + (qqqPass ? 50 : 0)

bool controlled_pullback = low <= support + PARITY_READY_DISTANCE_ATR * currentAtr and close > support and close >= open
bool confirmed_breakout = close > breakoutTrigger and close[1] <= breakoutTrigger and relativeVolume >= 1.20
float flagPole = close[5] - close[15]
float flagLow = ta.lowest(low, 5)
float flagRetracement = flagPole > 0 ? (close[5] - flagLow) / flagPole : 1.0
bool bull_flag = flagPole >= 2.0 * currentAtr and flagRetracement >= 0.10 and flagRetracement <= 0.50
float baseHigh = ta.highest(high, 25)
float baseLow = ta.lowest(low, 25)
bool flat_base = (baseHigh - baseLow) / baseHigh <= 0.12
float vcp60 = ta.highest(high, 60) - ta.lowest(low, 60)
float vcp40 = ta.highest(high, 40) - ta.lowest(low, 40)
float vcp20 = ta.highest(high, 20) - ta.lowest(low, 20)
bool vcp_tight_base = vcp40 <= 0.85 * vcp60 and vcp20 <= 0.85 * vcp40
bool ascending_triangle = ta.lowest(low, 15) > ta.lowest(low[15], 15) and close >= breakoutTrigger - PARITY_READY_DISTANCE_ATR * currentAtr
bool breakout_retest = close > breakoutTrigger and low <= breakoutTrigger + PARITY_READY_DISTANCE_ATR * currentAtr

bool productionPattern = controlled_pullback or confirmed_breakout or bull_flag or breakout_retest or flat_base or vcp_tight_base or ascending_triangle
float selectedTrigger = controlled_pullback ? ta.highest(high, 2) : bull_flag ? ta.highest(high, 5) : breakoutTrigger
float structuralInvalidation = controlled_pullback ? support - 0.20 * currentAtr : bull_flag ? flagLow : flat_base ? baseLow : math.max(sma50, selectedTrigger - 0.75 * currentAtr)
float extensionAtr = math.max(0.0, (close - selectedTrigger) / math.max(currentAtr, syminfo.mintick))
bool marketPass = not requireMarket or marketScore >= PARITY_MARKET_MINIMUM
bool researchEntry = completedBar and trendScore >= PARITY_TREND_MINIMUM and marketPass and productionPattern and close >= selectedTrigger and extensionAtr <= PARITY_MAX_EXTENSION_ATR

var int entryBar = na
var float entryUnderlyingPrice = na
if researchEntry and strategy.position_size == 0
    strategy.entry("Underlying proxy", strategy.long, comment = "Underlying proxy only")
    entryBar := bar_index
    entryUnderlyingPrice := close

int barsHeld = na(entryBar) ? 0 : bar_index - entryBar
bool noProgress = strategy.position_size > 0 and barsHeld >= noProgressBars and close <= entryUnderlyingPrice
bool maximumHold = strategy.position_size > 0 and barsHeld >= maximumHoldBars
bool structuralFailure = strategy.position_size > 0 and close < structuralInvalidation
if completedBar and (noProgress or maximumHold or structuralFailure)
    strategy.close("Underlying proxy", comment = "Research exit")
    entryBar := na
    entryUnderlyingPrice := na

plot(ema21, "EMA21", color = color.rgb(31, 90, 148), linewidth = 2)
plot(sma50, "SMA50", color = color.rgb(173, 101, 10), linewidth = 2)
plot(structuralInvalidation, "Underlying Structural Invalidation", color = color.rgb(170, 55, 55), style = plot.style_linebr)
plotshape(researchEntry and strategy.position_size == 0, title = "Underlying proxy signal", style = shape.labelup, location = location.belowbar, color = color.rgb(18, 122, 78), text = "PROXY", textcolor = color.white, size = size.tiny)

var table warningTable = table.new(position.top_right, 1, 3, frame_color = color.rgb(170, 55, 55), border_width = 2)
if barstate.islast
    table.cell(warningTable, 0, 0, "UNDERLYING PROXY RESEARCH", text_color = color.white, bgcolor = color.rgb(170, 55, 55))
    table.cell(warningTable, 0, 1, "NOT OPTION PERFORMANCE", text_color = color.rgb(170, 55, 55))
    table.cell(warningTable, 0, 2, "Research default - no promotion claim")
