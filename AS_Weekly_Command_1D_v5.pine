//@version=6
indicator(
    title = "Ali Swing Suite: Weekly Command 1D v5",
    shorttitle = "AS Weekly Command 1D v5",
    overlay = true,
    max_bars_back = 500,
    max_lines_count = 12
)

// config/strategy.yaml parity constants. Do not edit independently.
const int PARITY_SCHEMA_VERSION = 5
const int PARITY_TREND_MINIMUM = 80
const int PARITY_LEADERSHIP_MINIMUM = 70
const int PARITY_SETUP_MINIMUM = 75
const int PARITY_MARKET_MINIMUM = 70
const float PARITY_READY_DISTANCE_ATR = 0.30
const float PARITY_MAX_EXTENSION_ATR = 0.75
const int PARITY_MAX_CONFIRMED_AGE = 1

// Validation remains Research default; a technical finalist is Ready - Verify only.

string GROUP_CONTEXT = "Daily context"
string GROUP_MARKET = "Market and leadership"
string GROUP_DISPLAY = "Display"

int emaLength = input.int(21, "EMA length", minval = 5, group = GROUP_CONTEXT)
int mediumLength = input.int(50, "Medium SMA length", minval = 20, group = GROUP_CONTEXT)
int longLength = input.int(200, "Long SMA length", minval = 100, group = GROUP_CONTEXT)
int atrLength = input.int(14, "ATR length", minval = 5, group = GROUP_CONTEXT)
string peerSymbol = input.symbol("AMEX:SPY", "Leadership benchmark", group = GROUP_MARKET)
bool requireMarket = input.bool(true, "Require SPY and QQQ confirmation", group = GROUP_MARKET)
bool showEma21 = input.bool(true, "Show EMA21", group = GROUP_DISPLAY)
bool showSma50 = input.bool(true, "Show SMA50", group = GROUP_DISPLAY)
bool showSma200 = input.bool(true, "Show SMA200", group = GROUP_DISPLAY)
bool showPrimaryLevels = input.bool(true, "Show current trigger and invalidation", group = GROUP_DISPLAY)
bool showPlanningLevels = input.bool(false, "Show current pivot and 2R objective", group = GROUP_DISPLAY)
bool showInsights = input.bool(true, "Show quick insights", group = GROUP_DISPLAY)
int levelBarsBack = input.int(18, "Current level bars left", minval = 3, maxval = 100, group = GROUP_DISPLAY)
int levelBarsForward = input.int(8, "Current level bars right", minval = 1, maxval = 50, group = GROUP_DISPLAY)

f_score_color(int value, int minimum) =>
    value >= minimum ? color.rgb(52, 211, 153) :
     value >= minimum - 15 ? color.rgb(251, 191, 36) :
     color.rgb(248, 113, 113)

f_sync_level(line currentLine, bool visible, float level, color levelColor, string levelStyle, int levelWidth) =>
    line result = currentLine
    if barstate.islast
        if visible and not na(level)
            int leftBar = math.max(bar_index - levelBarsBack, 0)
            int rightBar = bar_index + levelBarsForward
            if na(result)
                result := line.new(leftBar, level, rightBar, level, xloc = xloc.bar_index, extend = extend.none, color = levelColor, style = levelStyle, width = levelWidth)
            else
                line.set_xy1(result, leftBar, level)
                line.set_xy2(result, rightBar, level)
                line.set_color(result, levelColor)
                line.set_style(result, levelStyle)
                line.set_width(result, levelWidth)
        else if not na(result)
            line.delete(result)
            result := na
    result

bool completedBar = barstate.isconfirmed
float sourceClose = completedBar ? close : close[1]
float sourcePriorClose = completedBar ? close[1] : close[2]
float sourceClose64 = completedBar ? close[64] : close[65]
float sourceOpen = completedBar ? open : open[1]
float sourceLow = completedBar ? low : low[1]
float sourceVolume = completedBar ? volume : volume[1]
float ema21Raw = ta.ema(close, emaLength)
float sma50Raw = ta.sma(close, mediumLength)
float sma200Raw = ta.sma(close, longLength)
float atrRaw = ta.atr(atrLength)
float ema21 = completedBar ? ema21Raw : ema21Raw[1]
float sma50 = completedBar ? sma50Raw : sma50Raw[1]
float sma200 = completedBar ? sma200Raw : sma200Raw[1]
float sma200Prior = completedBar ? sma200Raw[10] : sma200Raw[11]
float currentAtr = completedBar ? atrRaw : atrRaw[1]
float averageVolumeRaw = ta.sma(volume, 20)
float averageVolume = completedBar ? averageVolumeRaw : averageVolumeRaw[1]
float relativeVolume = averageVolume > 0 ? sourceVolume / averageVolume : 0.0
float pivotHighRaw = ta.pivothigh(high, 5, 3)
float pivotLowRaw = ta.pivotlow(low, 5, 3)
float latestPivotHighRaw = ta.valuewhen(not na(pivotHighRaw), pivotHighRaw, 0)
float latestPivotLowRaw = ta.valuewhen(not na(pivotLowRaw), pivotLowRaw, 0)
float latestPivotHigh = completedBar ? latestPivotHighRaw : latestPivotHighRaw[1]
float latestPivotLow = nz(completedBar ? latestPivotLowRaw : latestPivotLowRaw[1], sma50)
float nearestConfirmedPivot = latestPivotHigh > sourceClose ? latestPivotHigh : na
float breakoutLevelRaw = ta.highest(high[1], 20)
float breakoutLevel = completedBar ? breakoutLevelRaw : breakoutLevelRaw[1]

[weeklyClose, weeklyEma21] = request.security(
    syminfo.tickerid,
    "1W",
    [close[1], ta.ema(close, 21)[1]],
    lookahead = barmerge.lookahead_on
)
[spyCloseRaw, spySma50Raw, spySma200Raw] = request.security(
    "AMEX:SPY",
    "1D",
    [close, ta.sma(close, 50), ta.sma(close, 200)],
    lookahead = barmerge.lookahead_off
)
[qqqCloseRaw, qqqSma50Raw, qqqSma200Raw] = request.security(
    "NASDAQ:QQQ",
    "1D",
    [close, ta.sma(close, 50), ta.sma(close, 200)],
    lookahead = barmerge.lookahead_off
)
[peerCloseRaw, peerClose64Raw] = request.security(
    peerSymbol,
    "1D",
    [close, close[64]],
    lookahead = barmerge.lookahead_off
)
float spyClose = completedBar ? spyCloseRaw : spyCloseRaw[1]
float spySma50 = completedBar ? spySma50Raw : spySma50Raw[1]
float spySma200 = completedBar ? spySma200Raw : spySma200Raw[1]
float qqqClose = completedBar ? qqqCloseRaw : qqqCloseRaw[1]
float qqqSma50 = completedBar ? qqqSma50Raw : qqqSma50Raw[1]
float qqqSma200 = completedBar ? qqqSma200Raw : qqqSma200Raw[1]
float peerClose = completedBar ? peerCloseRaw : peerCloseRaw[1]
float peerClose64 = completedBar ? peerClose64Raw : peerClose64Raw[1]

bool weeklyAligned = weeklyClose > weeklyEma21
int trendScore = 0
trendScore += sourceClose > ema21 ? 15 : 0
trendScore += ema21 > sma50 ? 15 : 0
trendScore += sourceClose > sma50 ? 10 : 0
trendScore += sma50 > sma200 ? 20 : 0
trendScore += sourceClose > sma200 ? 15 : 0
trendScore += sma200 > sma200Prior ? 10 : 0
trendScore += weeklyAligned ? 15 : 0

bool spyPass = spyClose > spySma50 and spySma50 > spySma200
bool qqqPass = qqqClose > qqqSma50 and qqqSma50 > qqqSma200
int marketScore = (spyPass ? 50 : 0) + (qqqPass ? 50 : 0)
bool marketPass = not requireMarket or marketScore >= PARITY_MARKET_MINIMUM

bool indexLane = syminfo.ticker == "SPY" or syminfo.ticker == "QQQ"
float stockReturn64 = sourceClose64 > 0 ? sourceClose / sourceClose64 - 1.0 : 0.0
float peerReturn64 = peerClose64 > 0 ? peerClose / peerClose64 - 1.0 : 0.0
float relativeEdge = stockReturn64 - peerReturn64
int leadershipScore = relativeEdge >= 0.03 ? 100 : relativeEdge >= 0.0 ? 75 : relativeEdge >= -0.03 ? 50 : 20
bool leadershipPass = indexLane or leadershipScore >= PARITY_LEADERSHIP_MINIMUM

bool trendPass = trendScore >= PARITY_TREND_MINIMUM and sourceClose > sma200
float support = math.max(math.min(ema21, sourceClose), math.min(latestPivotLow, sourceClose))

bool controlled_pullback = trendPass and sourceLow <= support + PARITY_READY_DISTANCE_ATR * currentAtr and sourceClose > support and sourceClose >= sourceOpen
float pullbackTriggerRaw = ta.highest(high, 2)
float pullbackTrigger = completedBar ? pullbackTriggerRaw : pullbackTriggerRaw[1]
float pullbackInvalidation = support - 0.20 * currentAtr
int pullbackQuality = controlled_pullback ? 90 : 0

bool confirmed_breakout = trendPass and sourceClose > breakoutLevel and sourcePriorClose <= breakoutLevel and relativeVolume >= 1.20
float breakoutInvalidation = math.max(ema21, breakoutLevel - 0.50 * currentAtr)
int breakoutQuality = confirmed_breakout ? 92 : sourceClose >= breakoutLevel - PARITY_READY_DISTANCE_ATR * currentAtr ? 78 : 0

float flagPoleRaw = close[5] - close[15]
float flagReferenceCloseRaw = close[5]
float flagLowRaw = ta.lowest(low, 5)
float flagVolumeRaw = ta.sma(volume, 5)
float flagPriorVolumeRaw = ta.sma(volume[5], 10)
float flagTriggerRaw = ta.highest(high, 5)
float flagPole = completedBar ? flagPoleRaw : flagPoleRaw[1]
float flagReferenceClose = completedBar ? flagReferenceCloseRaw : flagReferenceCloseRaw[1]
float flagLow = completedBar ? flagLowRaw : flagLowRaw[1]
float flagVolume = completedBar ? flagVolumeRaw : flagVolumeRaw[1]
float flagPriorVolume = completedBar ? flagPriorVolumeRaw : flagPriorVolumeRaw[1]
float flagTrigger = completedBar ? flagTriggerRaw : flagTriggerRaw[1]
float flagRetracement = flagPole > 0 ? (flagReferenceClose - flagLow) / flagPole : 1.0
bool bull_flag = trendPass and flagPole >= 2.0 * currentAtr and flagRetracement >= 0.10 and flagRetracement <= 0.50 and flagVolume <= flagPriorVolume
int flagQuality = bull_flag ? 88 : 0

float breakoutLevel30Raw = ta.highest(high[1], 30)
bool breakoutEventRaw = close > breakoutLevel30Raw and volume >= averageVolumeRaw * 1.20
float priorBreakoutRaw = ta.valuewhen(breakoutEventRaw, breakoutLevel30Raw, 0)
int barsSinceBreakoutRaw = nz(ta.barssince(breakoutEventRaw), 10000)
float retestInvalidationRaw = ta.lowest(low, 8)
float priorBreakout = completedBar ? priorBreakoutRaw : priorBreakoutRaw[1]
int barsSinceBreakout = completedBar ? barsSinceBreakoutRaw : barsSinceBreakoutRaw[1]
float retestInvalidation = completedBar ? retestInvalidationRaw : retestInvalidationRaw[1]
bool breakout_retest = trendPass and barsSinceBreakout >= 1 and barsSinceBreakout <= 8 and sourceLow <= priorBreakout + PARITY_READY_DISTANCE_ATR * currentAtr and sourceClose > priorBreakout
int retestQuality = breakout_retest ? 90 : 0

float baseHighRaw = ta.highest(high, 25)
float baseLowRaw = ta.lowest(low, 25)
float baseVolumeRaw = ta.sma(volume, 10)
float basePriorVolumeRaw = ta.sma(volume[10], 15)
float flatTriggerRaw = ta.highest(high[1], 24)
float baseHigh = completedBar ? baseHighRaw : baseHighRaw[1]
float baseLow = completedBar ? baseLowRaw : baseLowRaw[1]
float baseVolume = completedBar ? baseVolumeRaw : baseVolumeRaw[1]
float basePriorVolume = completedBar ? basePriorVolumeRaw : basePriorVolumeRaw[1]
float flatTrigger = completedBar ? flatTriggerRaw : flatTriggerRaw[1]
float baseDepth = baseHigh > 0 ? (baseHigh - baseLow) / baseHigh : 1.0
bool flat_base = trendPass and baseDepth <= 0.12 and baseVolume <= basePriorVolume
int flatQuality = flat_base ? 84 : 0

float vcpRange60Raw = ta.highest(high, 60) - ta.lowest(low, 60)
float vcpRange40Raw = ta.highest(high, 40) - ta.lowest(low, 40)
float vcpRange20Raw = ta.highest(high, 20) - ta.lowest(low, 20)
float vcpVolumeRaw = ta.sma(volume, 20)
float vcpPriorVolumeRaw = ta.sma(volume[20], 20)
float vcpTriggerRaw = ta.highest(high[1], 19)
float vcpLowRaw = ta.lowest(low, 20)
float vcpRange60 = completedBar ? vcpRange60Raw : vcpRange60Raw[1]
float vcpRange40 = completedBar ? vcpRange40Raw : vcpRange40Raw[1]
float vcpRange20 = completedBar ? vcpRange20Raw : vcpRange20Raw[1]
float vcpVolume = completedBar ? vcpVolumeRaw : vcpVolumeRaw[1]
float vcpPriorVolume = completedBar ? vcpPriorVolumeRaw : vcpPriorVolumeRaw[1]
float vcpTrigger = completedBar ? vcpTriggerRaw : vcpTriggerRaw[1]
float vcpLow = completedBar ? vcpLowRaw : vcpLowRaw[1]
bool vcp_tight_base = trendPass and vcpRange40 <= 0.85 * vcpRange60 and vcpRange20 <= 0.85 * vcpRange40 and vcpVolume <= 0.80 * vcpPriorVolume
int vcpQuality = vcp_tight_base ? 86 : 0

float triangleTopRaw = ta.highest(high[1], 40)
float triangleLowRecentRaw = ta.lowest(low, 15)
float triangleLowPriorRaw = ta.lowest(low[15], 15)
float triangleTop = completedBar ? triangleTopRaw : triangleTopRaw[1]
float triangleLowRecent = completedBar ? triangleLowRecentRaw : triangleLowRecentRaw[1]
float triangleLowPrior = completedBar ? triangleLowPriorRaw : triangleLowPriorRaw[1]
bool ascending_triangle = trendPass and triangleLowRecent > triangleLowPrior and sourceClose >= triangleTop - PARITY_READY_DISTANCE_ATR * currentAtr
int triangleQuality = ascending_triangle ? 85 : 0

int selectedQuality = 0
int selectedPatternCode = 0
string selectedPattern = "No active setup"
float selectedTrigger = breakoutLevel
float selectedInvalidation = support - 0.20 * currentAtr

if controlled_pullback and pullbackQuality > selectedQuality
    selectedQuality := pullbackQuality
    selectedPatternCode := 1
    selectedPattern := "Controlled pullback"
    selectedTrigger := pullbackTrigger
    selectedInvalidation := pullbackInvalidation
if breakoutQuality > selectedQuality
    selectedQuality := breakoutQuality
    selectedPatternCode := 2
    selectedPattern := "Breakout"
    selectedTrigger := breakoutLevel
    selectedInvalidation := breakoutInvalidation
if bull_flag and flagQuality > selectedQuality
    selectedQuality := flagQuality
    selectedPatternCode := 3
    selectedPattern := "Bull flag"
    selectedTrigger := flagTrigger
    selectedInvalidation := flagLow
if breakout_retest and retestQuality > selectedQuality
    selectedQuality := retestQuality
    selectedPatternCode := 4
    selectedPattern := "Breakout retest"
    selectedTrigger := priorBreakout
    selectedInvalidation := retestInvalidation
if flat_base and flatQuality > selectedQuality
    selectedQuality := flatQuality
    selectedPatternCode := 5
    selectedPattern := "Flat base"
    selectedTrigger := flatTrigger
    selectedInvalidation := baseLow
if vcp_tight_base and vcpQuality > selectedQuality
    selectedQuality := vcpQuality
    selectedPatternCode := 6
    selectedPattern := "VCP / tight base"
    selectedTrigger := vcpTrigger
    selectedInvalidation := vcpLow
if ascending_triangle and triangleQuality > selectedQuality
    selectedQuality := triangleQuality
    selectedPatternCode := 7
    selectedPattern := "Ascending triangle"
    selectedTrigger := triangleTop
    selectedInvalidation := triangleLowRecent

float distanceAtr = (selectedTrigger - sourceClose) / math.max(currentAtr, syminfo.mintick)
bool crossedTrigger = sourceClose > selectedTrigger and sourcePriorClose <= selectedTrigger[1]
int confirmedAge = nz(ta.barssince(crossedTrigger), 10000)
bool patternReady = distanceAtr >= 0 and distanceAtr <= PARITY_READY_DISTANCE_ATR
bool patternConfirmed = confirmedAge <= PARITY_MAX_CONFIRMED_AGE and sourceClose <= selectedTrigger + PARITY_MAX_EXTENSION_ATR * currentAtr
bool patternExtended = sourceClose > selectedTrigger + PARITY_MAX_EXTENSION_ATR * currentAtr
bool patternFailed = sourceClose < selectedInvalidation
bool setupPass = selectedQuality >= PARITY_SETUP_MINIMUM and (patternReady or patternConfirmed)
bool recommendedTimeframe = timeframe.period == "1D"
bool technicalReady = completedBar and recommendedTimeframe and trendPass and leadershipPass and marketPass and setupPass and not patternExtended and not patternFailed
bool developing = trendScore >= 60 and selectedQuality > 0 and marketScore >= 50
int stateCode = technicalReady ? 2 : developing ? 1 : 0
int lifecycleCode = patternFailed ? 5 : patternExtended ? 4 : patternConfirmed ? 3 : patternReady ? 2 : selectedQuality > 0 ? 1 : 0
int laneCode = indexLane ? 1 : 2
string reviewState = not recommendedTimeframe ? "USE 1D" :
     patternFailed ? "FAILED" :
     patternExtended ? "EXTENDED" :
     technicalReady ? "READY - VERIFY" :
     developing ? "DEVELOPING" :
     "NO SETUP"
string lifecycle = selectedPatternCode == 0 ? "None" :
     patternFailed ? "Failed" :
     patternExtended ? "Extended" :
     patternConfirmed ? "Confirmed" :
     patternReady ? "Ready" :
     "Forming"
string nextInsight = not recommendedTimeframe ? "Switch chart to 1D" :
     patternFailed ? "Thesis invalidated" :
     patternExtended ? "Wait for reset" :
     not trendPass ? "Wait for trend" :
     not marketPass ? "Wait for market" :
     not leadershipPass ? "Wait for leadership" :
     selectedQuality < PARITY_SETUP_MINIMUM ? "Wait for setup" :
     not (patternReady or patternConfirmed) ? "Wait for trigger" :
     "Open 60m timing"
color reviewStateColor = not recommendedTimeframe ? color.rgb(251, 191, 36) :
     technicalReady ? color.rgb(52, 211, 153) :
     developing ? color.rgb(96, 165, 250) :
     patternFailed or patternExtended ? color.rgb(248, 113, 113) :
     color.rgb(203, 213, 225)

float structuralInvalidation = selectedInvalidation
float riskPerShare = math.max(selectedTrigger - structuralInvalidation, 0.25 * currentAtr)
float planningObjective2R = selectedTrigger + 2.0 * riskPerShare

plot(showEma21 ? ema21 : na, "EMA21", color = color.rgb(39, 110, 168), linewidth = 2, display = display.pane)
plot(showSma50 ? sma50 : na, "SMA50", color = color.rgb(200, 136, 42), linewidth = 1, display = display.pane)
plot(showSma200 ? sma200 : na, "SMA200", color = color.rgb(92, 101, 110), linewidth = 1, display = display.pane)

var line triggerLine = na
var line invalidationLine = na
var line pivotLine = na
var line objectiveLine = na
triggerLine := f_sync_level(triggerLine, showPrimaryLevels, selectedTrigger, color.rgb(20, 145, 91), line.style_solid, 2)
invalidationLine := f_sync_level(invalidationLine, showPrimaryLevels, structuralInvalidation, color.rgb(190, 67, 67), line.style_solid, 2)
pivotLine := f_sync_level(pivotLine, showPlanningLevels, nearestConfirmedPivot, color.rgb(190, 128, 35), line.style_dashed, 1)
objectiveLine := f_sync_level(objectiveLine, showPlanningLevels, planningObjective2R, color.rgb(55, 115, 178), line.style_dotted, 1)

plot(trendScore, "V5 Trend Score", display = display.data_window)
plot(leadershipScore, "V5 Leadership Score", display = display.data_window)
plot(selectedQuality, "V5 Setup Score", display = display.data_window)
plot(marketScore, "V5 Market Score", display = display.data_window)
plot(selectedPatternCode, "V5 Pattern Code", display = display.data_window)
plot(stateCode, "V5 State Code", display = display.data_window)
plot(laneCode, "V5 Lane Code", display = display.data_window)
plot(lifecycleCode, "V5 Lifecycle Code", display = display.data_window)
plot(recommendedTimeframe ? 1 : 0, "V5 Recommended Timeframe", display = display.data_window)
plot(selectedTrigger, "V5 Trigger", display = display.data_window)
plot(structuralInvalidation, "V5 Structural Invalidation", display = display.data_window)
plot(nearestConfirmedPivot, "V5 Confirmed Pivot", display = display.data_window)
plot(planningObjective2R, "V5 2R Planning Objective", display = display.data_window)

color panelHeader = color.new(color.rgb(20, 25, 31), 4)
color panelBody = color.new(color.rgb(31, 39, 47), 8)
color panelLabel = color.rgb(181, 191, 201)
color panelValue = color.rgb(241, 245, 249)
string distanceText = selectedPatternCode == 0 ? "n/a" : str.tostring(distanceAtr, "#.00") + " ATR"
string triggerText = selectedPatternCode == 0 ? "n/a" : str.tostring(selectedTrigger, format.mintick)
string invalidationText = selectedPatternCode == 0 ? "n/a" : str.tostring(structuralInvalidation, format.mintick)
color trendSetupColor = trendPass and selectedQuality >= PARITY_SETUP_MINIMUM ? color.rgb(52, 211, 153) :
     trendScore >= 60 and selectedQuality > 0 ? color.rgb(251, 191, 36) :
     color.rgb(248, 113, 113)
color marketLeadColor = marketPass and leadershipPass ? color.rgb(52, 211, 153) :
     marketScore >= 50 ? color.rgb(251, 191, 36) :
     color.rgb(248, 113, 113)

var table insightsTable = table.new(
    position.top_right,
    2,
    9,
    frame_color = color.new(color.rgb(148, 163, 184), 45),
    frame_width = 1,
    border_color = color.new(color.rgb(148, 163, 184), 78),
    border_width = 1
)
if barstate.islast and showInsights
    table.cell(insightsTable, 0, 0, "DAILY QUICK VIEW", text_color = color.white, bgcolor = panelHeader, text_size = size.small, text_halign = text.align_left)
    table.cell(insightsTable, 1, 0, syminfo.ticker + " | " + (indexLane ? "INDEX" : "LEADER"), text_color = color.white, bgcolor = panelHeader, text_size = size.small, text_halign = text.align_right)
    table.cell(insightsTable, 0, 1, "State", text_color = panelLabel, bgcolor = panelBody, text_size = size.small, text_halign = text.align_left)
    table.cell(insightsTable, 1, 1, reviewState, text_color = reviewStateColor, bgcolor = panelBody, text_size = size.small, text_halign = text.align_right)
    table.cell(insightsTable, 0, 2, "Pattern", text_color = panelLabel, bgcolor = panelBody, text_size = size.small, text_halign = text.align_left)
    table.cell(insightsTable, 1, 2, selectedPattern, text_color = panelValue, bgcolor = panelBody, text_size = size.small, text_halign = text.align_right)
    table.cell(insightsTable, 0, 3, "Lifecycle", text_color = panelLabel, bgcolor = panelBody, text_size = size.small, text_halign = text.align_left)
    table.cell(insightsTable, 1, 3, lifecycle + " | " + distanceText, text_color = panelValue, bgcolor = panelBody, text_size = size.small, text_halign = text.align_right)
    table.cell(insightsTable, 0, 4, "Trend / Setup", text_color = panelLabel, bgcolor = panelBody, text_size = size.small, text_halign = text.align_left)
    table.cell(insightsTable, 1, 4, str.tostring(trendScore) + " / " + str.tostring(selectedQuality), text_color = trendSetupColor, bgcolor = panelBody, text_size = size.small, text_halign = text.align_right)
    table.cell(insightsTable, 0, 5, "Market / Lead", text_color = panelLabel, bgcolor = panelBody, text_size = size.small, text_halign = text.align_left)
    table.cell(insightsTable, 1, 5, str.tostring(marketScore) + " / " + str.tostring(leadershipScore), text_color = marketLeadColor, bgcolor = panelBody, text_size = size.small, text_halign = text.align_right)
    table.cell(insightsTable, 0, 6, "Trigger", text_color = panelLabel, bgcolor = panelBody, text_size = size.small, text_halign = text.align_left)
    table.cell(insightsTable, 1, 6, triggerText, text_color = f_score_color(selectedQuality, PARITY_SETUP_MINIMUM), bgcolor = panelBody, text_size = size.small, text_halign = text.align_right)
    table.cell(insightsTable, 0, 7, "Invalidation", text_color = panelLabel, bgcolor = panelBody, text_size = size.small, text_halign = text.align_left)
    table.cell(insightsTable, 1, 7, invalidationText, text_color = color.rgb(248, 113, 113), bgcolor = panelBody, text_size = size.small, text_halign = text.align_right)
    table.cell(insightsTable, 0, 8, "Next", text_color = panelLabel, bgcolor = panelBody, text_size = size.small, text_halign = text.align_left)
    table.cell(insightsTable, 1, 8, nextInsight, text_color = color.rgb(125, 211, 252), bgcolor = panelBody, text_size = size.small, text_halign = text.align_right)

alertcondition(technicalReady and not technicalReady[1], "V5 daily setup ready for verification", "{{ticker}} has a completed daily Bullish Weekly Participation v5 setup. Verify event, data, and contract evidence.")
alertcondition(crossedTrigger and setupPass and completedBar, "V5 daily trigger confirmed", "{{ticker}} closed through its selected v5 daily trigger.")
alertcondition(sourceClose < structuralInvalidation and sourcePriorClose >= structuralInvalidation[1] and completedBar, "V5 structural invalidation", "{{ticker}} closed below its v5 structural invalidation.")
alertcondition(patternExtended and not patternExtended[1] and completedBar, "V5 extension warning", "{{ticker}} exceeded the v5 maximum confirmed extension.")
