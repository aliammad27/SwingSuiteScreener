//@version=6
indicator(
    title = "Ali Swing Suite: Weekly Timing 1H v5",
    shorttitle = "AS Weekly Timing 1H v5",
    overlay = true,
    max_bars_back = 500,
    max_labels_count = 100,
    max_lines_count = 60
)

// config/strategy.yaml parity constants. Do not edit independently.
const int PARITY_SCHEMA_VERSION = 5
const int PARITY_TIMING_MINIMUM = 75
const int PARITY_MINIMUM_COMPLETED_BARS = 80

string GROUP_TIMING = "Completed-hour timing"
string GROUP_DISPLAY = "Display"

int rsiLength = input.int(14, "RSI length", minval = 5, group = GROUP_TIMING)
int relativeVolumeLength = input.int(20, "Relative-volume length", minval = 10, group = GROUP_TIMING)
bool showAverages = input.bool(true, "Show EMA9, EMA21, and VWAP", group = GROUP_DISPLAY)
bool showLevels = input.bool(true, "Show tactical levels", group = GROUP_DISPLAY)
bool showTable = input.bool(true, "Show timing table", group = GROUP_DISPLAY)

f_score_color(int value) =>
    value >= PARITY_TIMING_MINIMUM ? color.rgb(18, 122, 78) :
     value >= 60 ? color.rgb(173, 101, 10) :
     color.rgb(170, 55, 55)

bool completedBar = barstate.isconfirmed
float ema9Raw = ta.ema(close, 9)
float ema21Raw = ta.ema(close, 21)
float vwapRaw = ta.vwap(hlc3)
float rsiRaw = ta.rsi(close, rsiLength)
[macdLineRaw, macdSignalRaw, macdHistogramRaw] = ta.macd(close, 12, 26, 9)
float relativeVolumeRaw = volume / math.max(ta.sma(volume, relativeVolumeLength), 1)
float sourceClose = completedBar ? close : close[1]
float sourceLow = completedBar ? low : low[1]
float ema9 = completedBar ? ema9Raw : ema9Raw[1]
float ema21 = completedBar ? ema21Raw : ema21Raw[1]
float sessionVwap = completedBar ? vwapRaw : vwapRaw[1]
float rsiValue = completedBar ? rsiRaw : rsiRaw[1]
float macdHistogram = completedBar ? macdHistogramRaw : macdHistogramRaw[1]
float priorMacdHistogram = completedBar ? macdHistogramRaw[1] : macdHistogramRaw[2]
float relativeVolume = completedBar ? relativeVolumeRaw : relativeVolumeRaw[1]

[dailyClose, dailyEma21, dailySma50, dailySma200] = request.security(
    syminfo.tickerid,
    "1D",
    [close[1], ta.ema(close, 21)[1], ta.sma(close, 50)[1], ta.sma(close, 200)[1]],
    lookahead = barmerge.lookahead_on
)
[spyClose, spyEma9, spyEma21] = request.security(
    "AMEX:SPY",
    "60",
    [close[1], ta.ema(close, 9)[1], ta.ema(close, 21)[1]],
    lookahead = barmerge.lookahead_on
)
[qqqClose, qqqEma9, qqqEma21] = request.security(
    "NASDAQ:QQQ",
    "60",
    [close[1], ta.ema(close, 9)[1], ta.ema(close, 21)[1]],
    lookahead = barmerge.lookahead_on
)

bool dailyAligned = dailyClose > dailyEma21 and dailyEma21 > dailySma50 and dailyClose > dailySma200
bool indexCore = syminfo.ticker == "SPY" or syminfo.ticker == "QQQ"
bool intradayMarketAligned = indexCore or (spyClose > spyEma9 and spyEma9 > spyEma21) or (qqqClose > qqqEma9 and qqqEma9 > qqqEma21)
bool higherLow = sourceLow > ta.lowest(low[1], 4)
bool reclaim = sourceClose > ema9 and close[1] <= ema9[1]
bool aboveTrend = sourceClose > ema9 and ema9 > ema21
bool aboveVwap = sourceClose > sessionVwap
bool rsiPass = rsiValue >= 52 and rsiValue <= 72
bool macdPass = macdHistogram > 0 and macdHistogram >= priorMacdHistogram
bool volumePass = relativeVolume >= 0.90

int timingScore = 0
timingScore += aboveTrend ? 20 : sourceClose > ema21 ? 10 : 0
timingScore += aboveVwap ? 15 : 0
timingScore += rsiPass ? 15 : rsiValue >= 48 ? 8 : 0
timingScore += macdPass ? 15 : macdHistogram > priorMacdHistogram ? 8 : 0
timingScore += volumePass ? 10 : 0
timingScore += higherLow ? 10 : 0
timingScore += reclaim ? 5 : 0
timingScore += intradayMarketAligned ? 10 : 0

int closeHourEt = hour(time_close, "America/New_York")
int closeMinuteEt = minute(time_close, "America/New_York")
int closeMinuteOfDay = closeHourEt * 60 + closeMinuteEt
bool entryWindow = closeMinuteOfDay >= 10 * 60 + 30 and closeMinuteOfDay <= 14 * 60 + 45
bool finalHourManagementOnly = closeMinuteOfDay > 14 * 60 + 45
bool enoughHistory = bar_index + 1 >= PARITY_MINIMUM_COMPLETED_BARS
bool recommendedTimeframe = timeframe.period == "60"
bool timingReady = completedBar and enoughHistory and recommendedTimeframe and entryWindow and dailyAligned and timingScore >= PARITY_TIMING_MINIMUM

float tacticalWarning = math.min(ema21, sessionVwap)
float tacticalFailure = ta.lowest(low, 4)
string timingState = timingReady ? "Entry timing confirmed" :
     finalHourManagementOnly ? "Management only" :
     not entryWindow ? "Outside entry window" :
     not dailyAligned ? "Daily blocked" :
     timingScore >= 60 ? "Improving" :
     "Not confirmed"

plot(showAverages ? ema9 : na, "1H EMA9", color = color.rgb(18, 122, 78), linewidth = 2)
plot(showAverages ? ema21 : na, "1H EMA21", color = color.rgb(31, 90, 148), linewidth = 2)
plot(showAverages ? sessionVwap : na, "Session VWAP", color = color.rgb(173, 101, 10), linewidth = 2)
plot(showLevels ? tacticalWarning : na, "Tactical Warning", color = color.rgb(173, 101, 10), style = plot.style_linebr)
plot(showLevels ? tacticalFailure : na, "Tactical Failure", color = color.rgb(170, 55, 55), style = plot.style_linebr)
plotshape(timingReady, title = "Completed-hour entry confirmation", style = shape.triangleup, location = location.belowbar, color = color.rgb(18, 122, 78), size = size.tiny)

plot(timingScore, "V5 Timing Score", display = display.data_window)
plot(rsiValue, "V5 RSI", display = display.data_window)
plot(macdHistogram, "V5 MACD Histogram", display = display.data_window)
plot(relativeVolume, "V5 Relative Volume", display = display.data_window)
plot(entryWindow ? 1 : 0, "V5 Entry Window", display = display.data_window)

var table timingTable = table.new(position.top_right, 2, 11, frame_color = color.rgb(210, 216, 222), border_width = 1)
if barstate.islast and showTable
    table.cell(timingTable, 0, 0, "WEEKLY TIMING V5", text_color = color.white, bgcolor = color.rgb(28, 36, 44))
    table.cell(timingTable, 1, 0, syminfo.ticker, text_color = color.white, bgcolor = color.rgb(28, 36, 44))
    table.cell(timingTable, 0, 1, "State")
    table.cell(timingTable, 1, 1, timingState)
    table.cell(timingTable, 0, 2, "Score")
    table.cell(timingTable, 1, 2, str.tostring(timingScore), text_color = f_score_color(timingScore))
    table.cell(timingTable, 0, 3, "Window")
    table.cell(timingTable, 1, 3, entryWindow ? "Entry eligible" : finalHourManagementOnly ? "Management only" : "Closed")
    table.cell(timingTable, 0, 4, "Daily")
    table.cell(timingTable, 1, 4, dailyAligned ? "Aligned" : "Blocked")
    table.cell(timingTable, 0, 5, "Market")
    table.cell(timingTable, 1, 5, intradayMarketAligned ? "Confirmed" : "Not confirmed")
    table.cell(timingTable, 0, 6, "RSI")
    table.cell(timingTable, 1, 6, str.tostring(rsiValue, "#.0"))
    table.cell(timingTable, 0, 7, "MACD hist")
    table.cell(timingTable, 1, 7, str.tostring(macdHistogram, "#.000"))
    table.cell(timingTable, 0, 8, "Rel volume")
    table.cell(timingTable, 1, 8, str.tostring(relativeVolume, "#.00"))
    table.cell(timingTable, 0, 9, "Warning")
    table.cell(timingTable, 1, 9, str.tostring(tacticalWarning, format.mintick))
    table.cell(timingTable, 0, 10, "Failure")
    table.cell(timingTable, 1, 10, str.tostring(tacticalFailure, format.mintick))

alertcondition(timingReady and not timingReady[1], "V5 completed-hour entry confirmation", "{{ticker}} has completed-hour v5 timing confirmation inside the entry window.")
alertcondition(sourceClose < tacticalWarning and close[1] >= tacticalWarning[1] and completedBar, "V5 tactical warning", "{{ticker}} closed below its v5 tactical warning level.")
alertcondition(sourceClose < tacticalFailure and close[1] >= tacticalFailure[1] and completedBar, "V5 tactical failure", "{{ticker}} closed below its v5 tactical failure level.")
alertcondition(finalHourManagementOnly and not finalHourManagementOnly[1] and completedBar, "V5 management-only window", "{{ticker}} has entered the v5 management-only window.")
