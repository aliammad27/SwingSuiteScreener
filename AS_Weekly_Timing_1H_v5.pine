//@version=6
indicator(
    title = "Ali Swing Suite: Weekly Timing 1H v5",
    shorttitle = "AS Weekly Timing 1H v5",
    overlay = true,
    max_bars_back = 500,
    max_lines_count = 8
)

// config/strategy.yaml parity constants. Do not edit independently.
const int PARITY_SCHEMA_VERSION = 5
const int PARITY_TIMING_MINIMUM = 75
const int PARITY_MINIMUM_COMPLETED_BARS = 80

string GROUP_TIMING = "Completed-hour timing"
string GROUP_DISPLAY = "Display"

int rsiLength = input.int(14, "RSI length", minval = 5, group = GROUP_TIMING)
int relativeVolumeLength = input.int(20, "Relative-volume length", minval = 10, group = GROUP_TIMING)
bool showAverages = input.bool(true, "Show EMA9, EMA21, and VWAP", group = GROUP_DISPLAY)
bool showTacticalLevels = input.bool(true, "Show current tactical levels", group = GROUP_DISPLAY)
int levelBarsBack = input.int(12, "Current level bars left", minval = 3, maxval = 60, group = GROUP_DISPLAY)
int levelBarsForward = input.int(6, "Current level bars right", minval = 1, maxval = 30, group = GROUP_DISPLAY)

f_sync_level(line currentLine, bool visible, float level, color levelColor, string levelStyle, int levelWidth) =>
    line result = currentLine
    if barstate.islast
        if visible and not na(level)
            int leftBar = math.max(bar_index - levelBarsBack, 0)
            int rightBar = bar_index + levelBarsForward
            if na(result)
                result := line.new(leftBar, level, rightBar, level, xloc = xloc.bar_index, extend = extend.none, color = levelColor, style = levelStyle, width = levelWidth)
            else
                line.set_xy1(result, leftBar, level)
                line.set_xy2(result, rightBar, level)
                line.set_color(result, levelColor)
                line.set_style(result, levelStyle)
                line.set_width(result, levelWidth)
        else if not na(result)
            line.delete(result)
            result := na
    result

bool completedBar = barstate.isconfirmed
float ema9Raw = ta.ema(close, 9)
float ema21Raw = ta.ema(close, 21)
float vwapRaw = ta.vwap(hlc3)
float rsiRaw = ta.rsi(close, rsiLength)
[_, _, macdHistogramRaw] = ta.macd(close, 12, 26, 9)
float relativeVolumeAverageRaw = ta.sma(volume, relativeVolumeLength)
float relativeVolumeRaw = volume / math.max(relativeVolumeAverageRaw, 1)
float priorLowestLowRaw = ta.lowest(low[1], 4)
float sourceClose = completedBar ? close : close[1]
float sourcePriorClose = completedBar ? close[1] : close[2]
float sourceLow = completedBar ? low : low[1]
int sourceCloseTime = completedBar ? time_close : time_close[1]
float ema9 = completedBar ? ema9Raw : ema9Raw[1]
float priorEma9 = completedBar ? ema9Raw[1] : ema9Raw[2]
float ema21 = completedBar ? ema21Raw : ema21Raw[1]
float sessionVwap = completedBar ? vwapRaw : vwapRaw[1]
float rsiValue = completedBar ? rsiRaw : rsiRaw[1]
float macdHistogram = completedBar ? macdHistogramRaw : macdHistogramRaw[1]
float priorMacdHistogram = completedBar ? macdHistogramRaw[1] : macdHistogramRaw[2]
float relativeVolume = completedBar ? relativeVolumeRaw : relativeVolumeRaw[1]
float priorLowestLow = completedBar ? priorLowestLowRaw : priorLowestLowRaw[1]

[dailyClose, dailyEma21, dailySma50, dailySma200] = request.security(
    syminfo.tickerid,
    "1D",
    [close[1], ta.ema(close, 21)[1], ta.sma(close, 50)[1], ta.sma(close, 200)[1]],
    lookahead = barmerge.lookahead_on
)
[spyCloseRaw, spyEma9Raw, spyEma21Raw] = request.security(
    "AMEX:SPY",
    "60",
    [close, ta.ema(close, 9), ta.ema(close, 21)],
    lookahead = barmerge.lookahead_off
)
[qqqCloseRaw, qqqEma9Raw, qqqEma21Raw] = request.security(
    "NASDAQ:QQQ",
    "60",
    [close, ta.ema(close, 9), ta.ema(close, 21)],
    lookahead = barmerge.lookahead_off
)
float spyClose = completedBar ? spyCloseRaw : spyCloseRaw[1]
float spyEma9 = completedBar ? spyEma9Raw : spyEma9Raw[1]
float spyEma21 = completedBar ? spyEma21Raw : spyEma21Raw[1]
float qqqClose = completedBar ? qqqCloseRaw : qqqCloseRaw[1]
float qqqEma9 = completedBar ? qqqEma9Raw : qqqEma9Raw[1]
float qqqEma21 = completedBar ? qqqEma21Raw : qqqEma21Raw[1]

bool dailyAligned = dailyClose > dailyEma21 and dailyEma21 > dailySma50 and dailyClose > dailySma200
bool indexCore = syminfo.ticker == "SPY" or syminfo.ticker == "QQQ"
bool intradayMarketAligned = indexCore or (spyClose > spyEma9 and spyEma9 > spyEma21) or (qqqClose > qqqEma9 and qqqEma9 > qqqEma21)
bool higherLow = sourceLow > priorLowestLow
bool reclaim = sourceClose > ema9 and sourcePriorClose <= priorEma9
bool aboveTrend = sourceClose > ema9 and ema9 > ema21
bool aboveVwap = sourceClose > sessionVwap
bool rsiPass = rsiValue >= 52 and rsiValue <= 72
bool macdPass = macdHistogram > 0 and macdHistogram >= priorMacdHistogram
bool volumePass = relativeVolume >= 0.90

int timingScore = 0
timingScore += aboveTrend ? 20 : sourceClose > ema21 ? 10 : 0
timingScore += aboveVwap ? 15 : 0
timingScore += rsiPass ? 15 : rsiValue >= 48 ? 8 : 0
timingScore += macdPass ? 15 : macdHistogram > priorMacdHistogram ? 8 : 0
timingScore += volumePass ? 10 : 0
timingScore += higherLow ? 10 : 0
timingScore += reclaim ? 5 : 0
timingScore += intradayMarketAligned ? 10 : 0

int closeHourEt = hour(sourceCloseTime, "America/New_York")
int closeMinuteEt = minute(sourceCloseTime, "America/New_York")
int closeMinuteOfDay = closeHourEt * 60 + closeMinuteEt
bool entryWindow = closeMinuteOfDay >= 10 * 60 + 30 and closeMinuteOfDay <= 14 * 60 + 45
bool finalHourManagementOnly = closeMinuteOfDay > 14 * 60 + 45
bool enoughHistory = bar_index + 1 >= PARITY_MINIMUM_COMPLETED_BARS
bool recommendedTimeframe = timeframe.period == "60"
bool timingReady = completedBar and enoughHistory and recommendedTimeframe and entryWindow and dailyAligned and intradayMarketAligned and timingScore >= PARITY_TIMING_MINIMUM
bool developing = entryWindow and dailyAligned and timingScore >= 60
int timingStateCode = timingReady ? 3 : finalHourManagementOnly ? 2 : developing ? 1 : 0

float tacticalWarning = math.min(ema21, sessionVwap)
float tacticalFailure = priorLowestLow
plot(showAverages ? ema9 : na, "1H EMA9", color = color.rgb(18, 122, 78), linewidth = 2, display = display.pane)
plot(showAverages ? ema21 : na, "1H EMA21", color = color.rgb(31, 90, 148), linewidth = 2, display = display.pane)
plot(showAverages ? sessionVwap : na, "Session VWAP", color = color.rgb(173, 101, 10), linewidth = 2, display = display.pane)

var line warningLine = na
var line failureLine = na
warningLine := f_sync_level(warningLine, showTacticalLevels, tacticalWarning, color.rgb(190, 128, 35), line.style_dashed, 1)
failureLine := f_sync_level(failureLine, showTacticalLevels, tacticalFailure, color.rgb(190, 67, 67), line.style_solid, 2)

plot(timingScore, "V5 Timing Score", display = display.data_window)
plot(rsiValue, "V5 RSI", display = display.data_window)
plot(macdHistogram, "V5 MACD Histogram", display = display.data_window)
plot(relativeVolume, "V5 Relative Volume", display = display.data_window)
plot(entryWindow ? 1 : 0, "V5 Entry Window", display = display.data_window)
plot(timingStateCode, "V5 Timing State Code", display = display.data_window)
plot(dailyAligned ? 1 : 0, "V5 Daily Aligned", display = display.data_window)
plot(intradayMarketAligned ? 1 : 0, "V5 Market Aligned", display = display.data_window)
plot(recommendedTimeframe ? 1 : 0, "V5 Recommended Timeframe", display = display.data_window)
plot(tacticalWarning, "V5 Tactical Warning", display = display.data_window)
plot(tacticalFailure, "V5 Tactical Failure", display = display.data_window)

alertcondition(timingReady and not timingReady[1], "V5 completed-hour entry confirmation", "{{ticker}} has completed-hour v5 timing confirmation inside the entry window.")
alertcondition(sourceClose < tacticalWarning and sourcePriorClose >= tacticalWarning[1] and completedBar, "V5 tactical warning", "{{ticker}} closed below its v5 tactical warning level.")
alertcondition(sourceClose < tacticalFailure and sourcePriorClose >= tacticalFailure[1] and completedBar, "V5 tactical failure", "{{ticker}} closed below its v5 tactical failure level.")
alertcondition(finalHourManagementOnly and not finalHourManagementOnly[1] and completedBar, "V5 management-only window", "{{ticker}} has entered the v5 management-only window.")
