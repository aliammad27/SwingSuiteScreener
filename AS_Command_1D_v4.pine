//@version=6
indicator(
    title = "Ali Swing Suite: Bullish Participation Command 1D v4",
    shorttitle = "AS Command 1D v4",
    overlay = true,
    max_bars_back = 500,
    max_labels_count = 200,
    max_lines_count = 100
)

// config/strategy.yaml parity constants. Do not edit independently.
const int PARITY_SCHEMA_VERSION = 4
const int PARITY_TREND_MINIMUM = 80
const int PARITY_LEADERSHIP_MINIMUM = 70
const int PARITY_SETUP_MINIMUM = 75
const int PARITY_MARKET_MINIMUM = 70
const float PARITY_READY_DISTANCE_ATR = 0.5
const float PARITY_MAX_EXTENSION_ATR = 1.0
const int PARITY_MAX_CONFIRMED_AGE = 3

string GROUP_TREND = "Trend and structure"
string GROUP_MARKET = "Market and leadership"
string GROUP_PATTERNS = "Bullish pattern library"
string GROUP_DISPLAY = "Display"

int emaLength = input.int(21, "EMA length", minval = 5, group = GROUP_TREND)
int mediumLength = input.int(50, "Medium SMA length", minval = 20, group = GROUP_TREND)
int longLength = input.int(200, "Long SMA length", minval = 100, group = GROUP_TREND)
int atrLength = input.int(14, "ATR length", minval = 5, group = GROUP_TREND)
int pivotLeft = input.int(5, "Pivot left bars", minval = 2, maxval = 10, group = GROUP_TREND)
int pivotRight = input.int(3, "Pivot right bars", minval = 2, maxval = 10, group = GROUP_TREND)
string peerSymbol = input.symbol("AMEX:SPY", "Peer benchmark", group = GROUP_MARKET)
bool useMarketProxy = input.bool(true, "Require market proxy", group = GROUP_MARKET)
bool showPatterns = input.bool(true, "Show selected pattern", group = GROUP_PATTERNS)
bool showLevels = input.bool(true, "Show trigger, invalidation, objective", group = GROUP_DISPLAY)
bool showAverages = input.bool(true, "Show moving averages", group = GROUP_DISPLAY)
bool tintBars = input.bool(true, "Tint bars by review state", group = GROUP_DISPLAY)
bool showTable = input.bool(true, "Show command table", group = GROUP_DISPLAY)

f_scoreColor(int value, int minimum) =>
    value >= minimum ? color.rgb(20, 125, 79) : value >= minimum - 15 ? color.rgb(154, 91, 8) : color.rgb(161, 57, 57)

f_stateColor(string value) =>
    value == "Ready" ? color.rgb(20, 125, 79) :
     value == "Ready - Verify" ? color.rgb(154, 91, 8) :
     value == "Developing" ? color.rgb(31, 90, 148) :
     color.rgb(101, 113, 125)

float ema21 = ta.ema(close, emaLength)
float sma50 = ta.sma(close, mediumLength)
float sma200 = ta.sma(close, longLength)
float sma200Prior = sma200[10]
float currentAtr = ta.atr(atrLength)
float avwap21 = ta.vwma(hlc3, 21)
float averageVolume = ta.sma(volume, 20)
float relativeVolume = averageVolume > 0 ? volume / averageVolume : 0.0
float pivotHigh = ta.pivothigh(high, pivotLeft, pivotRight)
float pivotLow = ta.pivotlow(low, pivotLeft, pivotRight)
float latestPivotHigh = nz(ta.valuewhen(not na(pivotHigh), pivotHigh, 0), ta.highest(high[1], 20))
float latestPivotLow = nz(ta.valuewhen(not na(pivotLow), pivotLow, 0), sma50)
float breakoutLevel = ta.highest(high[1], 20)
float support = math.max(math.max(math.min(ema21, close), math.min(avwap21, close)), math.min(latestPivotLow, close))
bool extended = close > ema21 + PARITY_MAX_EXTENSION_ATR * currentAtr

[weeklyClose, weeklyEma21] = request.security(
    syminfo.tickerid,
    "1W",
    [close[1], ta.ema(close, 21)[1]],
    lookahead = barmerge.lookahead_on
)
[spyClose, spySma50, spySma200] = request.security(
    "AMEX:SPY",
    "1D",
    [close[1], ta.sma(close, 50)[1], ta.sma(close, 200)[1]],
    lookahead = barmerge.lookahead_on
)
[qqqClose, qqqSma50, qqqSma200] = request.security(
    "NASDAQ:QQQ",
    "1D",
    [close[1], ta.sma(close, 50)[1], ta.sma(close, 200)[1]],
    lookahead = barmerge.lookahead_on
)
[peerClose, peerEma21] = request.security(
    peerSymbol,
    "1D",
    [close[1], ta.ema(close, 21)[1]],
    lookahead = barmerge.lookahead_on
)

bool weeklyAligned = weeklyClose > weeklyEma21
int trendScore = 0
trendScore += close > ema21 ? 15 : 0
trendScore += ema21 > sma50 ? 15 : 0
trendScore += close > sma50 ? 10 : 0
trendScore += sma50 > sma200 ? 20 : 0
trendScore += close > sma200 ? 15 : 0
trendScore += sma200 > sma200Prior ? 10 : 0
trendScore += weeklyAligned ? 15 : 0

bool spyPass = spyClose > spySma50 and spySma50 > spySma200
bool qqqPass = qqqClose > qqqSma50 and qqqSma50 > qqqSma200
int marketProxyScore = (spyPass ? 50 : 0) + (qqqPass ? 50 : 0)
bool marketPass = not useMarketProxy or marketProxyScore >= PARITY_MARKET_MINIMUM

bool indexCore = syminfo.ticker == "SPY" or syminfo.ticker == "QQQ"
float relativeLine = peerClose > 0 ? close / peerClose : na
float relativeAverage = ta.ema(relativeLine, 21)
bool relativeRising = relativeLine > relativeLine[5]
bool peerRising = peerClose > peerEma21 and peerClose > peerClose[5]
int leadershipScore = 0
leadershipScore += relativeLine > relativeAverage and relativeRising ? 50 : relativeLine > relativeAverage or relativeRising ? 25 : 0
leadershipScore += peerRising ? 25 : 0
leadershipScore += close / close[63] > peerClose / peerClose[63] ? 25 : 0

bool trendPass = trendScore >= PARITY_TREND_MINIMUM and close > sma200 and not extended
bool pullbackHold = trendPass and low <= support + 0.30 * currentAtr and close > support and close >= open
float pullbackTrigger = ta.highest(high, 2)
float pullbackInvalidation = support - 0.20 * currentAtr
float pullbackObjective = math.max(latestPivotHigh, close + 2.0 * (close - pullbackInvalidation))
int pullbackQuality = (pullbackHold ? 40 : 0) + (relativeVolume >= 0.65 and relativeVolume <= 1.60 ? 25 : 12) + (close >= open ? 20 : 8) + 15

bool confirmed_breakout = trendPass and close > breakoutLevel and close[1] <= breakoutLevel[1] and relativeVolume >= 1.20
float breakoutInvalidation = math.max(ema21, breakoutLevel - 0.50 * currentAtr)
float breakoutObjective = breakoutLevel + 2.0 * math.max(breakoutLevel - breakoutInvalidation, 0.25 * currentAtr)
int breakoutQuality = (confirmed_breakout ? 40 : 28) + (relativeVolume >= 1.20 ? 25 : 12) + (weeklyAligned ? 20 : 0) + (not extended ? 15 : 0)

float flagPole = close[5] - close[15]
float flagLow = ta.lowest(low, 5)
float flagRetracement = flagPole > 0 ? (close[5] - flagLow) / flagPole : 1.0
bool bull_flag = trendPass and flagPole >= 2.0 * currentAtr and flagRetracement >= 0.10 and flagRetracement <= 0.50 and ta.sma(volume, 5) <= ta.sma(volume[5], 10)
float flagTrigger = ta.highest(high, 5)
float flagObjective = flagTrigger + math.max(flagPole, 2.0 * currentAtr)
int flagQuality = (bull_flag ? 40 : 0) + (ta.sma(volume, 5) <= ta.sma(volume[5], 10) ? 25 : 10) + (trendScore >= PARITY_TREND_MINIMUM ? 20 : 10) + 15

float baseHigh = ta.highest(high, 25)
float baseLow = ta.lowest(low, 25)
float baseDepth = baseHigh > 0 ? (baseHigh - baseLow) / baseHigh : 1.0
bool flat_base = trendPass and baseDepth <= 0.12 and ta.sma(volume, 10) <= ta.sma(volume[10], 15)
float flatTrigger = ta.highest(high[1], 24)
float flatObjective = flatTrigger + math.max(flatTrigger - baseLow, 2.0 * currentAtr)
int flatQuality = (baseDepth <= 0.08 ? 40 : 28) + (ta.sma(volume, 10) <= ta.sma(volume[10], 15) ? 25 : 10) + (ema21 > sma50 ? 20 : 8) + 15

float triangleTop = ta.highest(high[1], 40)
float triangleLowRecent = ta.lowest(low, 15)
float triangleLowPrior = ta.lowest(low[15], 15)
bool ascending_triangle = trendPass and triangleLowRecent > triangleLowPrior and close >= triangleTop - 0.75 * currentAtr
float triangleObjective = triangleTop + math.max(triangleTop - triangleLowRecent, 2.0 * currentAtr)
int triangleQuality = (ascending_triangle ? 40 : 0) + (volume <= averageVolume ? 25 : 12) + (trendScore >= PARITY_TREND_MINIMUM ? 20 : 10) + 15

float vcpRange60 = ta.highest(high, 60) - ta.lowest(low, 60)
float vcpRange40 = ta.highest(high, 40) - ta.lowest(low, 40)
float vcpRange20 = ta.highest(high, 20) - ta.lowest(low, 20)
bool vcp_tight_base = trendPass and vcpRange40 <= 0.85 * vcpRange60 and vcpRange20 <= 0.85 * vcpRange40 and ta.sma(volume, 20) <= 0.80 * ta.sma(volume[20], 20)
float vcpTrigger = ta.highest(high[1], 19)
float vcpLow = ta.lowest(low, 20)
float vcpObjective = vcpTrigger + math.max(vcpRange60, 2.0 * currentAtr)
int vcpQuality = (vcp_tight_base ? 40 : 0) + (ta.sma(volume, 20) <= 0.80 * ta.sma(volume[20], 20) ? 25 : 12) + (vcpRange20 <= 0.70 * vcpRange60 ? 20 : 12) + 15

float cupLeftRim = ta.highest(high[90], 30)
float cupRightRim = ta.highest(high[15], 25)
float cupBottom = ta.lowest(low[15], 105)
float cupRim = math.max(cupLeftRim, cupRightRim)
float cupDepth = cupRim > 0 ? (cupRim - cupBottom) / cupRim : 1.0
float handleLow = ta.lowest(low, 15)
float handleDepth = cupRightRim > 0 ? (cupRightRim - handleLow) / cupRightRim : 1.0
bool cup_with_handle = trendPass and cupDepth >= 0.12 and cupDepth <= 0.35 and math.abs(cupLeftRim - cupRightRim) / cupRim <= 0.05 and handleDepth <= 0.12 and close >= cupRightRim - 0.75 * currentAtr
float cupObjective = cupRightRim + (cupRim - cupBottom)
int cupQuality = (cup_with_handle ? 40 : 0) + (ta.sma(volume, 15) <= ta.sma(volume[15], 30) ? 25 : 12) + (trendScore >= PARITY_TREND_MINIMUM ? 20 : 10) + 15

bool breakoutEvent = close > ta.highest(high[1], 30) and relativeVolume >= 1.20
float priorBreakout = ta.valuewhen(breakoutEvent, ta.highest(high[1], 30), 0)
int barsSinceBreakout = ta.barssince(breakoutEvent)
bool breakout_retest = trendPass and barsSinceBreakout >= 1 and barsSinceBreakout <= 8 and low <= priorBreakout + 0.50 * currentAtr and close > priorBreakout
float retestInvalidation = ta.lowest(low, 8)
float retestObjective = priorBreakout + math.max(priorBreakout - retestInvalidation, 2.0 * currentAtr)
int retestQuality = (breakout_retest ? 40 : 0) + 25 + (close >= open ? 20 : 10) + 15

float patternPivotLow = ta.pivotlow(low, 4, 3)
float bottomOne = ta.valuewhen(not na(patternPivotLow), patternPivotLow, 1)
float bottomTwo = ta.valuewhen(not na(patternPivotLow), patternPivotLow, 0)
int bottomBarOne = int(ta.valuewhen(not na(patternPivotLow), bar_index[3], 1))
int bottomBarTwo = int(ta.valuewhen(not na(patternPivotLow), bar_index[3], 0))
int bottomSpacing = bottomBarTwo - bottomBarOne
float doubleNeckline = ta.highest(high, 60)
bool double_bottom = trendPass and bottomSpacing >= 10 and bottomSpacing <= 60 and math.abs(bottomOne - bottomTwo) <= math.max(0.75 * currentAtr, math.min(bottomOne, bottomTwo) * 0.03) and close >= doubleNeckline - 0.75 * currentAtr
float doubleObjective = doubleNeckline + (doubleNeckline - math.min(bottomOne, bottomTwo))
int doubleQuality = (double_bottom ? 40 : 0) + (math.abs(bottomOne - bottomTwo) <= 0.35 * currentAtr ? 25 : 12) + 20 + 15

float shoulderLeft = ta.valuewhen(not na(patternPivotLow), patternPivotLow, 2)
float headLow = ta.valuewhen(not na(patternPivotLow), patternPivotLow, 1)
float shoulderRight = ta.valuewhen(not na(patternPivotLow), patternPivotLow, 0)
float ihsNeckline = ta.highest(high, 90)
bool inverse_head_and_shoulders = trendPass and headLow < math.min(shoulderLeft, shoulderRight) - 0.75 * currentAtr and math.abs(shoulderLeft - shoulderRight) <= math.max(0.80 * currentAtr, math.min(shoulderLeft, shoulderRight) * 0.03) and close >= ihsNeckline - 0.75 * currentAtr
float ihsObjective = ihsNeckline + (ihsNeckline - headLow)
int ihsQuality = (inverse_head_and_shoulders ? 40 : 0) + (math.abs(shoulderLeft - shoulderRight) <= 0.40 * currentAtr ? 25 : 12) + 20 + 15

float wedgeHighSlope = ta.linreg(high, 35, 0) - ta.linreg(high, 35, 1)
float wedgeLowSlope = ta.linreg(low, 35, 0) - ta.linreg(low, 35, 1)
float wedgeEarlyWidth = ta.sma(high[25] - low[25], 10)
float wedgeLateWidth = ta.sma(high - low, 10)
float wedgeUpper = ta.linreg(high, 35, 0)
bool falling_wedge = trendPass and wedgeHighSlope < wedgeLowSlope and wedgeLowSlope < 0 and wedgeLateWidth <= 0.80 * wedgeEarlyWidth and close >= wedgeUpper - 0.75 * currentAtr
float wedgeLow = ta.lowest(low, 12)
float wedgeObjective = wedgeUpper + math.max(ta.highest(high, 35) - ta.lowest(low, 35), 2.0 * currentAtr)
int wedgeQuality = (falling_wedge ? 40 : 0) + (wedgeLateWidth <= 0.65 * wedgeEarlyWidth ? 25 : 15) + 20 + (weeklyAligned ? 15 : 5)

float roundingLeftRim = ta.sma(high[72], 8)
float roundingRightRim = ta.sma(high, 8)
float roundingBottom = ta.lowest(low[20], 40)
float roundingRim = math.max(roundingLeftRim, roundingRightRim)
float roundingDepth = roundingRim > 0 ? (roundingRim - roundingBottom) / roundingRim : 1.0
bool rounding_base = trendPass and roundingDepth >= 0.08 and roundingDepth <= 0.30 and math.abs(roundingLeftRim - roundingRightRim) / roundingRim <= 0.06 and close > close[20] and close >= roundingRightRim - 0.75 * currentAtr
float roundingObjective = roundingRightRim + (roundingRim - roundingBottom)
int roundingQuality = (rounding_base ? 40 : 0) + (math.abs(roundingLeftRim - roundingRightRim) <= 0.50 * currentAtr ? 25 : 12) + 20 + 15

int selectedQuality = 0
string selectedPattern = "no_valid_setup"
float selectedTrigger = breakoutLevel
float selectedInvalidation = support - 0.20 * currentAtr
float selectedObjective = math.max(latestPivotHigh, close + 2.0 * currentAtr)

if pullbackHold and pullbackQuality > selectedQuality
    selectedQuality := pullbackQuality
    selectedPattern := "controlled_pullback"
    selectedTrigger := pullbackTrigger
    selectedInvalidation := pullbackInvalidation
    selectedObjective := pullbackObjective
if (confirmed_breakout or close >= breakoutLevel - currentAtr) and breakoutQuality > selectedQuality
    selectedQuality := breakoutQuality
    selectedPattern := "confirmed_breakout"
    selectedTrigger := breakoutLevel
    selectedInvalidation := breakoutInvalidation
    selectedObjective := breakoutObjective
if bull_flag and flagQuality > selectedQuality
    selectedQuality := flagQuality
    selectedPattern := "bull_flag"
    selectedTrigger := flagTrigger
    selectedInvalidation := flagLow
    selectedObjective := flagObjective
if flat_base and flatQuality > selectedQuality
    selectedQuality := flatQuality
    selectedPattern := "flat_base"
    selectedTrigger := flatTrigger
    selectedInvalidation := baseLow
    selectedObjective := flatObjective
if ascending_triangle and triangleQuality > selectedQuality
    selectedQuality := triangleQuality
    selectedPattern := "ascending_triangle"
    selectedTrigger := triangleTop
    selectedInvalidation := triangleLowRecent
    selectedObjective := triangleObjective
if vcp_tight_base and vcpQuality > selectedQuality
    selectedQuality := vcpQuality
    selectedPattern := "vcp_tight_base"
    selectedTrigger := vcpTrigger
    selectedInvalidation := vcpLow
    selectedObjective := vcpObjective
if cup_with_handle and cupQuality > selectedQuality
    selectedQuality := cupQuality
    selectedPattern := "cup_with_handle"
    selectedTrigger := cupRightRim
    selectedInvalidation := handleLow
    selectedObjective := cupObjective
if breakout_retest and retestQuality > selectedQuality
    selectedQuality := retestQuality
    selectedPattern := "breakout_retest"
    selectedTrigger := priorBreakout
    selectedInvalidation := retestInvalidation
    selectedObjective := retestObjective
if double_bottom and doubleQuality > selectedQuality
    selectedQuality := doubleQuality
    selectedPattern := "double_bottom"
    selectedTrigger := doubleNeckline
    selectedInvalidation := math.min(bottomOne, bottomTwo) - 0.20 * currentAtr
    selectedObjective := doubleObjective
if inverse_head_and_shoulders and ihsQuality > selectedQuality
    selectedQuality := ihsQuality
    selectedPattern := "inverse_head_and_shoulders"
    selectedTrigger := ihsNeckline
    selectedInvalidation := headLow - 0.20 * currentAtr
    selectedObjective := ihsObjective
if falling_wedge and wedgeQuality > selectedQuality
    selectedQuality := wedgeQuality
    selectedPattern := "falling_wedge"
    selectedTrigger := wedgeUpper
    selectedInvalidation := wedgeLow
    selectedObjective := wedgeObjective
if rounding_base and roundingQuality > selectedQuality
    selectedQuality := roundingQuality
    selectedPattern := "rounding_base"
    selectedTrigger := roundingRightRim
    selectedInvalidation := roundingBottom
    selectedObjective := roundingObjective

bool patternFailed = close < selectedInvalidation
bool breakoutNow = close > selectedTrigger and close[1] <= selectedTrigger[1]
int confirmedAge = nz(ta.barssince(breakoutNow), 10000)
float distanceToTriggerAtr = (selectedTrigger - close) / math.max(currentAtr, syminfo.mintick)
bool patternConfirmed = confirmedAge <= PARITY_MAX_CONFIRMED_AGE and close <= selectedTrigger + PARITY_MAX_EXTENSION_ATR * currentAtr
bool patternReady = distanceToTriggerAtr >= 0 and distanceToTriggerAtr <= PARITY_READY_DISTANCE_ATR
bool patternStale = confirmedAge > PARITY_MAX_CONFIRMED_AGE and close > selectedTrigger
string patternStatus = patternFailed ? "Failed" : patternConfirmed ? "Confirmed" : patternStale ? "Stale" : patternReady ? "Ready" : "Forming"
bool setupPass = selectedQuality >= PARITY_SETUP_MINIMUM and (patternReady or patternConfirmed)
bool leadershipPass = indexCore or leadershipScore >= PARITY_LEADERSHIP_MINIMUM
string reviewState = trendPass and setupPass and marketPass and leadershipPass ? "Ready - Verify" : trendScore >= 60 and selectedQuality > 0 and marketProxyScore >= 45 ? "Developing" : "Rejected"
int stateCode = reviewState == "Ready - Verify" ? 3 : reviewState == "Developing" ? 1 : 0
bool signalBarAllowed = barstate.isconfirmed

plot(showAverages ? ema21 : na, "EMA21", color = color.rgb(31, 90, 148), linewidth = 2)
plot(showAverages ? sma50 : na, "SMA50", color = color.rgb(180, 105, 20), linewidth = 2)
plot(showAverages ? sma200 : na, "SMA200", color = color.rgb(23, 33, 43), linewidth = 2)
plot(showAverages ? avwap21 : na, "21-bar AVWAP", color = color.rgb(20, 125, 79), linewidth = 1)
plot(showLevels ? selectedTrigger : na, "Selected Trigger", color = color.rgb(20, 125, 79), style = plot.style_linebr)
plot(showLevels ? selectedInvalidation : na, "Underlying Invalidation", color = color.rgb(161, 57, 57), style = plot.style_linebr)
plot(showLevels ? selectedObjective : na, "Planning Objective", color = color.rgb(31, 90, 148), style = plot.style_linebr)
plotshape(showPatterns and setupPass and signalBarAllowed, title = "Bullish Pattern Ready", style = shape.labelup, location = location.belowbar, color = f_stateColor(reviewState), text = "V4", textcolor = color.white, size = size.tiny)
barcolor(tintBars ? reviewState == "Ready - Verify" ? color.new(color.rgb(20, 125, 79), 55) : reviewState == "Developing" ? color.new(color.rgb(31, 90, 148), 68) : na : na)

plot(trendScore, "V4 Trend Score", display = display.data_window)
plot(leadershipScore, "V4 Leadership Score", display = display.data_window)
plot(selectedQuality, "V4 Setup Score", display = display.data_window)
plot(marketProxyScore, "V4 Market Proxy Score", display = display.data_window)
plot(stateCode, "V4 Review State Code", display = display.data_window)

var table commandTable = table.new(position.top_right, 2, 11, frame_color = color.rgb(216, 222, 229), border_width = 1)
if barstate.islast and showTable
    table.cell(commandTable, 0, 0, "BULLISH V4", text_color = color.white, bgcolor = color.rgb(23, 33, 43))
    table.cell(commandTable, 1, 0, syminfo.ticker, text_color = color.white, bgcolor = color.rgb(23, 33, 43))
    table.cell(commandTable, 0, 1, "State")
    table.cell(commandTable, 1, 1, reviewState, text_color = f_stateColor(reviewState))
    table.cell(commandTable, 0, 2, "Pattern")
    table.cell(commandTable, 1, 2, selectedPattern)
    table.cell(commandTable, 0, 3, "Pattern status")
    table.cell(commandTable, 1, 3, patternStatus)
    table.cell(commandTable, 0, 4, "Trend")
    table.cell(commandTable, 1, 4, str.tostring(trendScore), text_color = f_scoreColor(trendScore, PARITY_TREND_MINIMUM))
    table.cell(commandTable, 0, 5, "Leadership")
    table.cell(commandTable, 1, 5, indexCore ? "N/A - index" : str.tostring(leadershipScore), text_color = indexCore ? color.rgb(101, 113, 125) : f_scoreColor(leadershipScore, PARITY_LEADERSHIP_MINIMUM))
    table.cell(commandTable, 0, 6, "Setup")
    table.cell(commandTable, 1, 6, str.tostring(selectedQuality), text_color = f_scoreColor(selectedQuality, PARITY_SETUP_MINIMUM))
    table.cell(commandTable, 0, 7, "Market proxy")
    table.cell(commandTable, 1, 7, str.tostring(marketProxyScore), text_color = f_scoreColor(marketProxyScore, PARITY_MARKET_MINIMUM))
    table.cell(commandTable, 0, 8, "Trigger")
    table.cell(commandTable, 1, 8, str.tostring(selectedTrigger, format.mintick))
    table.cell(commandTable, 0, 9, "Invalidation")
    table.cell(commandTable, 1, 9, str.tostring(selectedInvalidation, format.mintick))
    table.cell(commandTable, 0, 10, "Objective")
    table.cell(commandTable, 1, 10, str.tostring(selectedObjective, format.mintick))

alertcondition(reviewState == "Ready - Verify" and reviewState[1] != "Ready - Verify" and signalBarAllowed, "Bullish v4 setup ready for verification", "{{ticker}} has a Bullish Participation v4 setup ready for live contract and event verification.")
alertcondition(breakoutNow and setupPass and signalBarAllowed, "Bullish v4 trigger confirmed", "{{ticker}} closed through the selected Bullish Participation v4 trigger.")
alertcondition(close < selectedInvalidation and close[1] >= selectedInvalidation[1] and signalBarAllowed, "Bullish v4 invalidation", "{{ticker}} closed below the selected underlying invalidation.")
alertcondition(extended and not extended[1] and signalBarAllowed, "Bullish v4 extension warning", "{{ticker}} is extended beyond the Bullish Participation v4 trend boundary.")
