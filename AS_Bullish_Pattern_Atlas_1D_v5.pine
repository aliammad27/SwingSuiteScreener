//@version=6
indicator(
    title = "Ali Swing Suite: Bullish Pattern Atlas 1D v5",
    shorttitle = "AS Pattern Atlas 1D v5",
    overlay = true,
    max_bars_back = 500,
    max_lines_count = 8
)

// config/strategy.yaml parity constants. Do not edit independently.
const int PARITY_SCHEMA_VERSION = 5
const float PARITY_READY_DISTANCE_ATR = 0.30
const float PARITY_MAX_EXTENSION_ATR = 0.75
const int PARITY_MAX_CONFIRMED_AGE = 1

string GROUP_DISPLAY = "Atlas display"
bool includeContextPatterns = input.bool(false, "Include context-only patterns", group = GROUP_DISPLAY)
bool showCurrentGeometry = input.bool(true, "Show current trigger and invalidation", group = GROUP_DISPLAY)
bool showInsights = input.bool(true, "Show quick insights", group = GROUP_DISPLAY)
int levelBarsBack = input.int(18, "Current level bars left", minval = 3, maxval = 100, group = GROUP_DISPLAY)
int levelBarsForward = input.int(8, "Current level bars right", minval = 1, maxval = 50, group = GROUP_DISPLAY)

f_sync_level(line currentLine, bool visible, float level, color levelColor, string levelStyle, int levelWidth) =>
    line result = currentLine
    if barstate.islast
        if visible and not na(level)
            int leftBar = math.max(bar_index - levelBarsBack, 0)
            int rightBar = bar_index + levelBarsForward
            if na(result)
                result := line.new(leftBar, level, rightBar, level, xloc = xloc.bar_index, extend = extend.none, color = levelColor, style = levelStyle, width = levelWidth)
            else
                line.set_xy1(result, leftBar, level)
                line.set_xy2(result, rightBar, level)
                line.set_color(result, levelColor)
                line.set_style(result, levelStyle)
                line.set_width(result, levelWidth)
        else if not na(result)
            line.delete(result)
            result := na
    result

bool completedBar = barstate.isconfirmed
float sourceClose = completedBar ? close : close[1]
float sourcePriorClose = completedBar ? close[1] : close[2]
float sourceOpen = completedBar ? open : open[1]
float sourceLow = completedBar ? low : low[1]
float sourceVolume = completedBar ? volume : volume[1]

float currentAtrRaw = ta.atr(14)
float ema21Raw = ta.ema(close, 21)
float sma50Raw = ta.sma(close, 50)
float sma200Raw = ta.sma(close, 200)
float averageVolumeRaw = ta.sma(volume, 20)
float currentAtr = completedBar ? currentAtrRaw : currentAtrRaw[1]
float ema21 = completedBar ? ema21Raw : ema21Raw[1]
float sma50 = completedBar ? sma50Raw : sma50Raw[1]
float sma200 = completedBar ? sma200Raw : sma200Raw[1]
float averageVolume = completedBar ? averageVolumeRaw : averageVolumeRaw[1]
bool trendPass = sourceClose > ema21 and ema21 > sma50 and sma50 > sma200
float relativeVolume = averageVolume > 0 ? sourceVolume / averageVolume : 0.0

float pivotLowRaw = ta.pivotlow(low, 4, 3)
float latestPivotLowRaw = ta.valuewhen(not na(pivotLowRaw), pivotLowRaw, 0)
float latestPivotLow = nz(completedBar ? latestPivotLowRaw : latestPivotLowRaw[1], sma50)
float support = math.max(math.min(ema21, sourceClose), math.min(latestPivotLow, sourceClose))
bool controlled_pullback = trendPass and sourceLow <= support + PARITY_READY_DISTANCE_ATR * currentAtr and sourceClose > support and sourceClose >= sourceOpen
float pullbackTriggerRaw = ta.highest(high, 2)
float pullbackTrigger = completedBar ? pullbackTriggerRaw : pullbackTriggerRaw[1]
float pullbackInvalidation = support - 0.20 * currentAtr

float breakoutTriggerRaw = ta.highest(high[1], 20)
float breakoutTrigger = completedBar ? breakoutTriggerRaw : breakoutTriggerRaw[1]
bool confirmed_breakout = trendPass and sourceClose > breakoutTrigger and sourcePriorClose <= breakoutTrigger and relativeVolume >= 1.20
float breakoutInvalidation = math.max(ema21, breakoutTrigger - 0.50 * currentAtr)

float flagPoleRaw = close[5] - close[15]
float flagReferenceCloseRaw = close[5]
float flagLowRaw = ta.lowest(low, 5)
float flagVolumeRaw = ta.sma(volume, 5)
float flagPriorVolumeRaw = ta.sma(volume[5], 10)
float flagTriggerRaw = ta.highest(high, 5)
float flagPole = completedBar ? flagPoleRaw : flagPoleRaw[1]
float flagReferenceClose = completedBar ? flagReferenceCloseRaw : flagReferenceCloseRaw[1]
float flagLow = completedBar ? flagLowRaw : flagLowRaw[1]
float flagVolume = completedBar ? flagVolumeRaw : flagVolumeRaw[1]
float flagPriorVolume = completedBar ? flagPriorVolumeRaw : flagPriorVolumeRaw[1]
float flagTrigger = completedBar ? flagTriggerRaw : flagTriggerRaw[1]
float flagRetracement = flagPole > 0 ? (flagReferenceClose - flagLow) / flagPole : 1.0
bool bull_flag = trendPass and flagPole >= 2.0 * currentAtr and flagRetracement >= 0.10 and flagRetracement <= 0.50 and flagVolume <= flagPriorVolume

float breakoutLevel30Raw = ta.highest(high[1], 30)
bool breakoutEventRaw = close > breakoutLevel30Raw and volume >= averageVolumeRaw * 1.20
float priorBreakoutRaw = ta.valuewhen(breakoutEventRaw, breakoutLevel30Raw, 0)
int barsSinceBreakoutRaw = nz(ta.barssince(breakoutEventRaw), 10000)
float retestInvalidationRaw = ta.lowest(low, 8)
float priorBreakout = completedBar ? priorBreakoutRaw : priorBreakoutRaw[1]
int barsSinceBreakout = completedBar ? barsSinceBreakoutRaw : barsSinceBreakoutRaw[1]
float retestInvalidation = completedBar ? retestInvalidationRaw : retestInvalidationRaw[1]
bool breakout_retest = trendPass and barsSinceBreakout >= 1 and barsSinceBreakout <= 8 and sourceLow <= priorBreakout + PARITY_READY_DISTANCE_ATR * currentAtr and sourceClose > priorBreakout

float baseHighRaw = ta.highest(high, 25)
float baseLowRaw = ta.lowest(low, 25)
float baseVolumeRaw = ta.sma(volume, 10)
float basePriorVolumeRaw = ta.sma(volume[10], 15)
float flatTriggerRaw = ta.highest(high[1], 24)
float baseHigh = completedBar ? baseHighRaw : baseHighRaw[1]
float baseLow = completedBar ? baseLowRaw : baseLowRaw[1]
float baseVolume = completedBar ? baseVolumeRaw : baseVolumeRaw[1]
float basePriorVolume = completedBar ? basePriorVolumeRaw : basePriorVolumeRaw[1]
float flatTrigger = completedBar ? flatTriggerRaw : flatTriggerRaw[1]
float baseDepth = baseHigh > 0 ? (baseHigh - baseLow) / baseHigh : 1.0
bool flat_base = trendPass and baseDepth <= 0.12 and baseVolume <= basePriorVolume

float vcpRange60Raw = ta.highest(high, 60) - ta.lowest(low, 60)
float vcpRange40Raw = ta.highest(high, 40) - ta.lowest(low, 40)
float vcpRange20Raw = ta.highest(high, 20) - ta.lowest(low, 20)
float vcpVolumeRaw = ta.sma(volume, 20)
float vcpPriorVolumeRaw = ta.sma(volume[20], 20)
float vcpTriggerRaw = ta.highest(high[1], 19)
float vcpLowRaw = ta.lowest(low, 20)
float vcpRange60 = completedBar ? vcpRange60Raw : vcpRange60Raw[1]
float vcpRange40 = completedBar ? vcpRange40Raw : vcpRange40Raw[1]
float vcpRange20 = completedBar ? vcpRange20Raw : vcpRange20Raw[1]
float vcpVolume = completedBar ? vcpVolumeRaw : vcpVolumeRaw[1]
float vcpPriorVolume = completedBar ? vcpPriorVolumeRaw : vcpPriorVolumeRaw[1]
float vcpTrigger = completedBar ? vcpTriggerRaw : vcpTriggerRaw[1]
float vcpLow = completedBar ? vcpLowRaw : vcpLowRaw[1]
bool vcp_tight_base = trendPass and vcpRange40 <= 0.85 * vcpRange60 and vcpRange20 <= 0.85 * vcpRange40 and vcpVolume <= 0.80 * vcpPriorVolume

float triangleTopRaw = ta.highest(high[1], 40)
float triangleLowRecentRaw = ta.lowest(low, 15)
float triangleLowPriorRaw = ta.lowest(low[15], 15)
float triangleTop = completedBar ? triangleTopRaw : triangleTopRaw[1]
float triangleLowRecent = completedBar ? triangleLowRecentRaw : triangleLowRecentRaw[1]
float triangleLowPrior = completedBar ? triangleLowPriorRaw : triangleLowPriorRaw[1]
bool ascending_triangle = trendPass and triangleLowRecent > triangleLowPrior and sourceClose >= triangleTop - PARITY_READY_DISTANCE_ATR * currentAtr

float cupLeftRimRaw = ta.highest(high[90], 30)
float cupRightRimRaw = ta.highest(high[15], 25)
float cupBottomRaw = ta.lowest(low[15], 105)
float handleLowRaw = ta.lowest(low, 15)
float cupLeftRim = completedBar ? cupLeftRimRaw : cupLeftRimRaw[1]
float cupRightRim = completedBar ? cupRightRimRaw : cupRightRimRaw[1]
float cupBottom = completedBar ? cupBottomRaw : cupBottomRaw[1]
float handleLow = completedBar ? handleLowRaw : handleLowRaw[1]
float cupRim = math.max(cupLeftRim, cupRightRim)
float cupDepth = cupRim > 0 ? (cupRim - cupBottom) / cupRim : 1.0
float handleDepth = cupRightRim > 0 ? (cupRightRim - handleLow) / cupRightRim : 1.0
bool cup_with_handle = trendPass and cupRim > 0 and cupDepth >= 0.12 and cupDepth <= 0.35 and math.abs(cupLeftRim - cupRightRim) / cupRim <= 0.05 and handleDepth <= 0.12

float bottomOneRaw = ta.valuewhen(not na(pivotLowRaw), pivotLowRaw, 1)
float bottomTwoRaw = ta.valuewhen(not na(pivotLowRaw), pivotLowRaw, 0)
int bottomBarOneRaw = int(ta.valuewhen(not na(pivotLowRaw), bar_index[3], 1))
int bottomBarTwoRaw = int(ta.valuewhen(not na(pivotLowRaw), bar_index[3], 0))
float doubleNecklineRaw = ta.highest(high, 60)
float bottomOne = completedBar ? bottomOneRaw : bottomOneRaw[1]
float bottomTwo = completedBar ? bottomTwoRaw : bottomTwoRaw[1]
int bottomBarOne = completedBar ? bottomBarOneRaw : bottomBarOneRaw[1]
int bottomBarTwo = completedBar ? bottomBarTwoRaw : bottomBarTwoRaw[1]
float doubleNeckline = completedBar ? doubleNecklineRaw : doubleNecklineRaw[1]
bool double_bottom = trendPass and bottomBarTwo - bottomBarOne >= 10 and bottomBarTwo - bottomBarOne <= 60 and math.abs(bottomOne - bottomTwo) <= math.max(0.75 * currentAtr, math.min(bottomOne, bottomTwo) * 0.03)

float shoulderLeftRaw = ta.valuewhen(not na(pivotLowRaw), pivotLowRaw, 2)
float headLowRaw = ta.valuewhen(not na(pivotLowRaw), pivotLowRaw, 1)
float shoulderRightRaw = ta.valuewhen(not na(pivotLowRaw), pivotLowRaw, 0)
float ihsNecklineRaw = ta.highest(high, 90)
float shoulderLeft = completedBar ? shoulderLeftRaw : shoulderLeftRaw[1]
float headLow = completedBar ? headLowRaw : headLowRaw[1]
float shoulderRight = completedBar ? shoulderRightRaw : shoulderRightRaw[1]
float ihsNeckline = completedBar ? ihsNecklineRaw : ihsNecklineRaw[1]
bool inverse_head_and_shoulders = trendPass and headLow < math.min(shoulderLeft, shoulderRight) - 0.75 * currentAtr and math.abs(shoulderLeft - shoulderRight) <= math.max(0.80 * currentAtr, math.min(shoulderLeft, shoulderRight) * 0.03)

float wedgeHighCurrentRaw = ta.linreg(high, 35, 0)
float wedgeHighPriorRaw = ta.linreg(high, 35, 1)
float wedgeLowCurrentRaw = ta.linreg(low, 35, 0)
float wedgeLowPriorRaw = ta.linreg(low, 35, 1)
float wedgeEarlyWidthRaw = ta.sma(high[25] - low[25], 10)
float wedgeLateWidthRaw = ta.sma(high - low, 10)
float wedgeLowRaw = ta.lowest(low, 12)
float wedgeHighCurrent = completedBar ? wedgeHighCurrentRaw : wedgeHighCurrentRaw[1]
float wedgeHighPrior = completedBar ? wedgeHighPriorRaw : wedgeHighPriorRaw[1]
float wedgeLowCurrent = completedBar ? wedgeLowCurrentRaw : wedgeLowCurrentRaw[1]
float wedgeLowPrior = completedBar ? wedgeLowPriorRaw : wedgeLowPriorRaw[1]
float wedgeEarlyWidth = completedBar ? wedgeEarlyWidthRaw : wedgeEarlyWidthRaw[1]
float wedgeLateWidth = completedBar ? wedgeLateWidthRaw : wedgeLateWidthRaw[1]
float wedgeUpper = wedgeHighCurrent
float wedgeLow = completedBar ? wedgeLowRaw : wedgeLowRaw[1]
float wedgeHighSlope = wedgeHighCurrent - wedgeHighPrior
float wedgeLowSlope = wedgeLowCurrent - wedgeLowPrior
bool falling_wedge = trendPass and wedgeHighSlope < wedgeLowSlope and wedgeLowSlope < 0 and wedgeLateWidth <= 0.80 * wedgeEarlyWidth

float roundingLeftRimRaw = ta.sma(high[72], 8)
float roundingRightRimRaw = ta.sma(high, 8)
float roundingBottomRaw = ta.lowest(low[20], 40)
float roundingLeftRim = completedBar ? roundingLeftRimRaw : roundingLeftRimRaw[1]
float roundingRightRim = completedBar ? roundingRightRimRaw : roundingRightRimRaw[1]
float roundingBottom = completedBar ? roundingBottomRaw : roundingBottomRaw[1]
float roundingRim = math.max(roundingLeftRim, roundingRightRim)
float roundingDepth = roundingRim > 0 ? (roundingRim - roundingBottom) / roundingRim : 1.0
bool rounding_base = trendPass and roundingRim > 0 and roundingDepth >= 0.08 and roundingDepth <= 0.30 and math.abs(roundingLeftRim - roundingRightRim) / roundingRim <= 0.06

int selectedPatternCode = 0
int selectedClassCode = 0
float selectedTrigger = na
float selectedInvalidation = na

if controlled_pullback
    selectedPatternCode := 1
    selectedClassCode := 1
    selectedTrigger := pullbackTrigger
    selectedInvalidation := pullbackInvalidation
else if confirmed_breakout or sourceClose >= breakoutTrigger - PARITY_READY_DISTANCE_ATR * currentAtr
    selectedPatternCode := 2
    selectedClassCode := 1
    selectedTrigger := breakoutTrigger
    selectedInvalidation := breakoutInvalidation
else if bull_flag
    selectedPatternCode := 3
    selectedClassCode := 1
    selectedTrigger := flagTrigger
    selectedInvalidation := flagLow
else if breakout_retest
    selectedPatternCode := 4
    selectedClassCode := 1
    selectedTrigger := priorBreakout
    selectedInvalidation := retestInvalidation
else if flat_base
    selectedPatternCode := 5
    selectedClassCode := 1
    selectedTrigger := flatTrigger
    selectedInvalidation := baseLow
else if vcp_tight_base
    selectedPatternCode := 6
    selectedClassCode := 1
    selectedTrigger := vcpTrigger
    selectedInvalidation := vcpLow
else if ascending_triangle
    selectedPatternCode := 7
    selectedClassCode := 1
    selectedTrigger := triangleTop
    selectedInvalidation := triangleLowRecent
else if includeContextPatterns and cup_with_handle
    selectedPatternCode := 8
    selectedClassCode := 2
    selectedTrigger := cupRightRim
    selectedInvalidation := handleLow
else if includeContextPatterns and double_bottom
    selectedPatternCode := 9
    selectedClassCode := 2
    selectedTrigger := doubleNeckline
    selectedInvalidation := math.min(bottomOne, bottomTwo)
else if includeContextPatterns and inverse_head_and_shoulders
    selectedPatternCode := 10
    selectedClassCode := 2
    selectedTrigger := ihsNeckline
    selectedInvalidation := headLow
else if includeContextPatterns and falling_wedge
    selectedPatternCode := 11
    selectedClassCode := 2
    selectedTrigger := wedgeUpper
    selectedInvalidation := wedgeLow
else if includeContextPatterns and rounding_base
    selectedPatternCode := 12
    selectedClassCode := 2
    selectedTrigger := roundingRightRim
    selectedInvalidation := roundingBottom

float distanceAtr = not na(selectedTrigger) ? (selectedTrigger - sourceClose) / math.max(currentAtr, syminfo.mintick) : na
bool crossedTrigger = not na(selectedTrigger) and sourceClose > selectedTrigger and sourcePriorClose <= selectedTrigger[1]
int confirmedAge = nz(ta.barssince(crossedTrigger), 10000)
bool failed = not na(selectedInvalidation) and sourceClose < selectedInvalidation
bool extended = not na(selectedTrigger) and sourceClose > selectedTrigger + PARITY_MAX_EXTENSION_ATR * currentAtr
bool ready = distanceAtr >= 0 and distanceAtr <= PARITY_READY_DISTANCE_ATR
bool confirmed = confirmedAge <= PARITY_MAX_CONFIRMED_AGE
int lifecycleCode = failed ? 5 : extended ? 4 : confirmed ? 3 : ready ? 2 : selectedPatternCode > 0 ? 1 : 0
bool recommendedTimeframe = timeframe.period == "1D"
string selectedPattern = selectedPatternCode == 1 ? "Controlled pullback" :
     selectedPatternCode == 2 ? "Breakout" :
     selectedPatternCode == 3 ? "Bull flag" :
     selectedPatternCode == 4 ? "Breakout retest" :
     selectedPatternCode == 5 ? "Flat base" :
     selectedPatternCode == 6 ? "VCP / tight base" :
     selectedPatternCode == 7 ? "Ascending triangle" :
     selectedPatternCode == 8 ? "Cup with handle" :
     selectedPatternCode == 9 ? "Double bottom" :
     selectedPatternCode == 10 ? "Inverse H&S" :
     selectedPatternCode == 11 ? "Falling wedge" :
     selectedPatternCode == 12 ? "Rounding base" :
     "No active pattern"
string selectedClass = selectedClassCode == 1 ? "Production" :
     selectedClassCode == 2 ? "Context only" :
     "None"
string lifecycle = selectedPatternCode == 0 ? "None" :
     failed ? "Failed" :
     extended ? "Extended" :
     confirmed ? "Confirmed" :
     ready ? "Ready" :
     "Forming"
string atlasInsight = not recommendedTimeframe ? "Switch chart to 1D" :
     selectedPatternCode == 0 ? "No active pattern" :
     failed ? "Pattern failed" :
     extended ? "Wait for reset" :
     selectedClassCode == 2 ? "Context only; observe" :
     ready ? "Near production trigger" :
     confirmed ? "Fresh confirmation" :
     "Still forming"
color lifecycleColor = failed or extended ? color.rgb(248, 113, 113) :
     confirmed or ready ? color.rgb(52, 211, 153) :
     selectedPatternCode > 0 ? color.rgb(251, 191, 36) :
     color.rgb(203, 213, 225)

var line triggerLine = na
var line invalidationLine = na
color triggerColor = selectedClassCode == 1 ? color.rgb(20, 145, 91) : color.rgb(190, 128, 35)
triggerLine := f_sync_level(triggerLine, showCurrentGeometry, selectedTrigger, triggerColor, line.style_solid, 2)
invalidationLine := f_sync_level(invalidationLine, showCurrentGeometry, selectedInvalidation, color.rgb(190, 67, 67), line.style_solid, 2)

// Pattern codes: 1 pullback, 2 breakout, 3 bull flag, 4 retest, 5 flat base,
// 6 VCP, 7 ascending triangle, 8 cup/handle, 9 double bottom, 10 inverse H&S,
// 11 falling wedge, 12 rounding base. Class: 1 production, 2 context only.
// Lifecycle: 0 none, 1 forming, 2 ready, 3 confirmed, 4 extended, 5 failed.
plot(selectedPatternCode, "V5 Pattern Code", display = display.data_window)
plot(selectedClassCode, "V5 Pattern Class", display = display.data_window)
plot(lifecycleCode, "V5 Lifecycle Code", display = display.data_window)
plot(recommendedTimeframe ? 1 : 0, "V5 Recommended Timeframe", display = display.data_window)
plot(distanceAtr, "V5 Distance ATR", display = display.data_window)
plot(selectedTrigger, "V5 Pattern Trigger", display = display.data_window)
plot(selectedInvalidation, "V5 Pattern Invalidation", display = display.data_window)

color panelHeader = color.new(color.rgb(20, 25, 31), 4)
color panelBody = color.new(color.rgb(31, 39, 47), 8)
color panelLabel = color.rgb(181, 191, 201)
color panelValue = color.rgb(241, 245, 249)
string distanceText = selectedPatternCode == 0 or na(distanceAtr) ? "n/a" : str.tostring(distanceAtr, "#.00") + " ATR"
string triggerText = selectedPatternCode == 0 or na(selectedTrigger) ? "n/a" : str.tostring(selectedTrigger, format.mintick)
string invalidationText = selectedPatternCode == 0 or na(selectedInvalidation) ? "n/a" : str.tostring(selectedInvalidation, format.mintick)

var table insightsTable = table.new(
    position.bottom_right,
    2,
    8,
    frame_color = color.new(color.rgb(148, 163, 184), 45),
    frame_width = 1,
    border_color = color.new(color.rgb(148, 163, 184), 78),
    border_width = 1
)
if barstate.islast and showInsights
    table.cell(insightsTable, 0, 0, "PATTERN QUICK VIEW", text_color = color.white, bgcolor = panelHeader, text_size = size.small, text_halign = text.align_left)
    table.cell(insightsTable, 1, 0, syminfo.ticker, text_color = color.white, bgcolor = panelHeader, text_size = size.small, text_halign = text.align_right)
    table.cell(insightsTable, 0, 1, "Pattern", text_color = panelLabel, bgcolor = panelBody, text_size = size.small, text_halign = text.align_left)
    table.cell(insightsTable, 1, 1, selectedPattern, text_color = panelValue, bgcolor = panelBody, text_size = size.small, text_halign = text.align_right)
    table.cell(insightsTable, 0, 2, "Class", text_color = panelLabel, bgcolor = panelBody, text_size = size.small, text_halign = text.align_left)
    table.cell(insightsTable, 1, 2, selectedClass, text_color = selectedClassCode == 1 ? color.rgb(52, 211, 153) : selectedClassCode == 2 ? color.rgb(251, 191, 36) : panelValue, bgcolor = panelBody, text_size = size.small, text_halign = text.align_right)
    table.cell(insightsTable, 0, 3, "Lifecycle", text_color = panelLabel, bgcolor = panelBody, text_size = size.small, text_halign = text.align_left)
    table.cell(insightsTable, 1, 3, lifecycle, text_color = lifecycleColor, bgcolor = panelBody, text_size = size.small, text_halign = text.align_right)
    table.cell(insightsTable, 0, 4, "Distance", text_color = panelLabel, bgcolor = panelBody, text_size = size.small, text_halign = text.align_left)
    table.cell(insightsTable, 1, 4, distanceText, text_color = panelValue, bgcolor = panelBody, text_size = size.small, text_halign = text.align_right)
    table.cell(insightsTable, 0, 5, "Trigger", text_color = panelLabel, bgcolor = panelBody, text_size = size.small, text_halign = text.align_left)
    table.cell(insightsTable, 1, 5, triggerText, text_color = color.rgb(52, 211, 153), bgcolor = panelBody, text_size = size.small, text_halign = text.align_right)
    table.cell(insightsTable, 0, 6, "Invalidation", text_color = panelLabel, bgcolor = panelBody, text_size = size.small, text_halign = text.align_left)
    table.cell(insightsTable, 1, 6, invalidationText, text_color = color.rgb(248, 113, 113), bgcolor = panelBody, text_size = size.small, text_halign = text.align_right)
    table.cell(insightsTable, 0, 7, "Insight", text_color = panelLabel, bgcolor = panelBody, text_size = size.small, text_halign = text.align_left)
    table.cell(insightsTable, 1, 7, atlasInsight, text_color = color.rgb(125, 211, 252), bgcolor = panelBody, text_size = size.small, text_halign = text.align_right)

alertcondition(selectedClassCode == 1 and lifecycleCode == 2 and completedBar and recommendedTimeframe, "V5 production pattern ready", "{{ticker}} has a completed-bar production pattern inside the v5 ready distance.")
alertcondition(selectedClassCode == 2 and lifecycleCode == 2 and completedBar and recommendedTimeframe, "V5 context pattern observed", "{{ticker}} has a context-only bullish pattern. It is not a v5 production entry pattern.")
