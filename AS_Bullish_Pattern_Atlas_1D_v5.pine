//@version=6
indicator(
    title = "Ali Swing Suite: Bullish Pattern Atlas 1D v5",
    shorttitle = "AS Pattern Atlas 1D v5",
    overlay = true,
    max_bars_back = 500,
    max_labels_count = 250,
    max_lines_count = 100
)

// config/strategy.yaml parity constants. Do not edit independently.
const int PARITY_SCHEMA_VERSION = 5
const float PARITY_READY_DISTANCE_ATR = 0.30
const float PARITY_MAX_EXTENSION_ATR = 0.75
const int PARITY_MAX_CONFIRMED_AGE = 1

string GROUP_DISPLAY = "Atlas display"
bool showProduction = input.bool(true, "Show production patterns", group = GROUP_DISPLAY)
bool showContext = input.bool(true, "Show context-only patterns", group = GROUP_DISPLAY)
bool showGeometry = input.bool(true, "Show selected geometry", group = GROUP_DISPLAY)
bool showTable = input.bool(true, "Show atlas table", group = GROUP_DISPLAY)

bool completedBar = barstate.isconfirmed
float sourceClose = completedBar ? close : close[1]
float sourceOpen = completedBar ? open : open[1]
float sourceLow = completedBar ? low : low[1]
float currentAtrRaw = ta.atr(14)
float currentAtr = completedBar ? currentAtrRaw : currentAtrRaw[1]
float ema21 = completedBar ? ta.ema(close, 21) : ta.ema(close, 21)[1]
float sma50 = completedBar ? ta.sma(close, 50) : ta.sma(close, 50)[1]
float sma200 = completedBar ? ta.sma(close, 200) : ta.sma(close, 200)[1]
bool trendPass = sourceClose > ema21 and ema21 > sma50 and sma50 > sma200
float averageVolume = ta.sma(volume, 20)
float relativeVolume = averageVolume > 0 ? volume / averageVolume : 0.0

float pivotLowRaw = ta.pivotlow(low, 4, 3)
float latestPivotLow = nz(ta.valuewhen(not na(pivotLowRaw), pivotLowRaw, 0), sma50)
float support = math.max(math.min(ema21, sourceClose), math.min(latestPivotLow, sourceClose))
bool controlled_pullback = trendPass and sourceLow <= support + PARITY_READY_DISTANCE_ATR * currentAtr and sourceClose > support and sourceClose >= sourceOpen
float pullbackTrigger = ta.highest(high, 2)
float pullbackInvalidation = support - 0.20 * currentAtr

float breakoutTrigger = ta.highest(high[1], 20)
bool confirmed_breakout = trendPass and sourceClose > breakoutTrigger and close[1] <= breakoutTrigger and relativeVolume >= 1.20
float breakoutInvalidation = math.max(ema21, breakoutTrigger - 0.50 * currentAtr)

float flagPole = close[5] - close[15]
float flagLow = ta.lowest(low, 5)
float flagRetracement = flagPole > 0 ? (close[5] - flagLow) / flagPole : 1.0
bool bull_flag = trendPass and flagPole >= 2.0 * currentAtr and flagRetracement >= 0.10 and flagRetracement <= 0.50 and ta.sma(volume, 5) <= ta.sma(volume[5], 10)
float flagTrigger = ta.highest(high, 5)

bool breakoutEvent = close > ta.highest(high[1], 30) and volume >= averageVolume * 1.20
float priorBreakout = ta.valuewhen(breakoutEvent, ta.highest(high[1], 30), 0)
int barsSinceBreakout = nz(ta.barssince(breakoutEvent), 10000)
bool breakout_retest = trendPass and barsSinceBreakout >= 1 and barsSinceBreakout <= 8 and sourceLow <= priorBreakout + PARITY_READY_DISTANCE_ATR * currentAtr and sourceClose > priorBreakout
float retestInvalidation = ta.lowest(low, 8)

float baseHigh = ta.highest(high, 25)
float baseLow = ta.lowest(low, 25)
float baseDepth = baseHigh > 0 ? (baseHigh - baseLow) / baseHigh : 1.0
bool flat_base = trendPass and baseDepth <= 0.12 and ta.sma(volume, 10) <= ta.sma(volume[10], 15)
float flatTrigger = ta.highest(high[1], 24)

float vcpRange60 = ta.highest(high, 60) - ta.lowest(low, 60)
float vcpRange40 = ta.highest(high, 40) - ta.lowest(low, 40)
float vcpRange20 = ta.highest(high, 20) - ta.lowest(low, 20)
bool vcp_tight_base = trendPass and vcpRange40 <= 0.85 * vcpRange60 and vcpRange20 <= 0.85 * vcpRange40 and ta.sma(volume, 20) <= 0.80 * ta.sma(volume[20], 20)
float vcpTrigger = ta.highest(high[1], 19)
float vcpLow = ta.lowest(low, 20)

float triangleTop = ta.highest(high[1], 40)
float triangleLowRecent = ta.lowest(low, 15)
float triangleLowPrior = ta.lowest(low[15], 15)
bool ascending_triangle = trendPass and triangleLowRecent > triangleLowPrior and sourceClose >= triangleTop - PARITY_READY_DISTANCE_ATR * currentAtr

float cupLeftRim = ta.highest(high[90], 30)
float cupRightRim = ta.highest(high[15], 25)
float cupBottom = ta.lowest(low[15], 105)
float cupRim = math.max(cupLeftRim, cupRightRim)
float cupDepth = cupRim > 0 ? (cupRim - cupBottom) / cupRim : 1.0
float handleLow = ta.lowest(low, 15)
float handleDepth = cupRightRim > 0 ? (cupRightRim - handleLow) / cupRightRim : 1.0
bool cup_with_handle = trendPass and cupDepth >= 0.12 and cupDepth <= 0.35 and math.abs(cupLeftRim - cupRightRim) / cupRim <= 0.05 and handleDepth <= 0.12

float bottomOne = ta.valuewhen(not na(pivotLowRaw), pivotLowRaw, 1)
float bottomTwo = ta.valuewhen(not na(pivotLowRaw), pivotLowRaw, 0)
int bottomBarOne = int(ta.valuewhen(not na(pivotLowRaw), bar_index[3], 1))
int bottomBarTwo = int(ta.valuewhen(not na(pivotLowRaw), bar_index[3], 0))
float doubleNeckline = ta.highest(high, 60)
bool double_bottom = trendPass and bottomBarTwo - bottomBarOne >= 10 and bottomBarTwo - bottomBarOne <= 60 and math.abs(bottomOne - bottomTwo) <= math.max(0.75 * currentAtr, math.min(bottomOne, bottomTwo) * 0.03)

float shoulderLeft = ta.valuewhen(not na(pivotLowRaw), pivotLowRaw, 2)
float headLow = ta.valuewhen(not na(pivotLowRaw), pivotLowRaw, 1)
float shoulderRight = ta.valuewhen(not na(pivotLowRaw), pivotLowRaw, 0)
float ihsNeckline = ta.highest(high, 90)
bool inverse_head_and_shoulders = trendPass and headLow < math.min(shoulderLeft, shoulderRight) - 0.75 * currentAtr and math.abs(shoulderLeft - shoulderRight) <= math.max(0.80 * currentAtr, math.min(shoulderLeft, shoulderRight) * 0.03)

float wedgeHighSlope = ta.linreg(high, 35, 0) - ta.linreg(high, 35, 1)
float wedgeLowSlope = ta.linreg(low, 35, 0) - ta.linreg(low, 35, 1)
float wedgeEarlyWidth = ta.sma(high[25] - low[25], 10)
float wedgeLateWidth = ta.sma(high - low, 10)
float wedgeUpper = ta.linreg(high, 35, 0)
bool falling_wedge = trendPass and wedgeHighSlope < wedgeLowSlope and wedgeLowSlope < 0 and wedgeLateWidth <= 0.80 * wedgeEarlyWidth
float wedgeLow = ta.lowest(low, 12)

float roundingLeftRim = ta.sma(high[72], 8)
float roundingRightRim = ta.sma(high, 8)
float roundingBottom = ta.lowest(low[20], 40)
float roundingRim = math.max(roundingLeftRim, roundingRightRim)
float roundingDepth = roundingRim > 0 ? (roundingRim - roundingBottom) / roundingRim : 1.0
bool rounding_base = trendPass and roundingDepth >= 0.08 and roundingDepth <= 0.30 and math.abs(roundingLeftRim - roundingRightRim) / roundingRim <= 0.06

string selectedPattern = "none"
string selectedClass = "none"
float selectedTrigger = na
float selectedInvalidation = na

if controlled_pullback
    selectedPattern := "controlled_pullback"
    selectedClass := "production"
    selectedTrigger := pullbackTrigger
    selectedInvalidation := pullbackInvalidation
else if confirmed_breakout or sourceClose >= breakoutTrigger - PARITY_READY_DISTANCE_ATR * currentAtr
    selectedPattern := "confirmed_breakout"
    selectedClass := "production"
    selectedTrigger := breakoutTrigger
    selectedInvalidation := breakoutInvalidation
else if bull_flag
    selectedPattern := "bull_flag"
    selectedClass := "production"
    selectedTrigger := flagTrigger
    selectedInvalidation := flagLow
else if breakout_retest
    selectedPattern := "breakout_retest"
    selectedClass := "production"
    selectedTrigger := priorBreakout
    selectedInvalidation := retestInvalidation
else if flat_base
    selectedPattern := "flat_base"
    selectedClass := "production"
    selectedTrigger := flatTrigger
    selectedInvalidation := baseLow
else if vcp_tight_base
    selectedPattern := "vcp_tight_base"
    selectedClass := "production"
    selectedTrigger := vcpTrigger
    selectedInvalidation := vcpLow
else if ascending_triangle
    selectedPattern := "ascending_triangle"
    selectedClass := "production"
    selectedTrigger := triangleTop
    selectedInvalidation := triangleLowRecent
else if cup_with_handle
    selectedPattern := "cup_with_handle"
    selectedClass := "context only"
    selectedTrigger := cupRightRim
    selectedInvalidation := handleLow
else if double_bottom
    selectedPattern := "double_bottom"
    selectedClass := "context only"
    selectedTrigger := doubleNeckline
    selectedInvalidation := math.min(bottomOne, bottomTwo)
else if inverse_head_and_shoulders
    selectedPattern := "inverse_head_and_shoulders"
    selectedClass := "context only"
    selectedTrigger := ihsNeckline
    selectedInvalidation := headLow
else if falling_wedge
    selectedPattern := "falling_wedge"
    selectedClass := "context only"
    selectedTrigger := wedgeUpper
    selectedInvalidation := wedgeLow
else if rounding_base
    selectedPattern := "rounding_base"
    selectedClass := "context only"
    selectedTrigger := roundingRightRim
    selectedInvalidation := roundingBottom

float distanceAtr = not na(selectedTrigger) ? (selectedTrigger - sourceClose) / math.max(currentAtr, syminfo.mintick) : na
bool crossedTrigger = not na(selectedTrigger) and sourceClose > selectedTrigger and close[1] <= selectedTrigger[1]
int confirmedAge = nz(ta.barssince(crossedTrigger), 10000)
bool extended = not na(selectedTrigger) and sourceClose > selectedTrigger + PARITY_MAX_EXTENSION_ATR * currentAtr
string lifecycle = sourceClose < selectedInvalidation ? "Failed" :
     extended ? "Extended" :
     confirmedAge <= PARITY_MAX_CONFIRMED_AGE ? "Confirmed" :
     distanceAtr >= 0 and distanceAtr <= PARITY_READY_DISTANCE_ATR ? "Ready" :
     "Forming"

color productionColor = color.rgb(18, 122, 78)
color contextColor = color.rgb(173, 101, 10)
plot(showGeometry ? selectedTrigger : na, "Selected Pattern Trigger", color = selectedClass == "production" ? productionColor : contextColor, style = plot.style_linebr, linewidth = 2)
plot(showGeometry ? selectedInvalidation : na, "Selected Pattern Invalidation", color = color.rgb(170, 55, 55), style = plot.style_linebr)

plotshape(showProduction and controlled_pullback and completedBar, "Controlled Pullback", shape.labelup, location.belowbar, productionColor, text = "PB", textcolor = color.white, size = size.tiny)
plotshape(showProduction and confirmed_breakout and completedBar, "Confirmed Breakout", shape.labelup, location.belowbar, productionColor, text = "BO", textcolor = color.white, size = size.tiny)
plotshape(showProduction and bull_flag and completedBar, "Bull Flag", shape.labelup, location.belowbar, productionColor, text = "BF", textcolor = color.white, size = size.tiny)
plotshape(showProduction and breakout_retest and completedBar, "Breakout Retest", shape.labelup, location.belowbar, productionColor, text = "RT", textcolor = color.white, size = size.tiny)
plotshape(showProduction and flat_base and completedBar, "Flat Base", shape.labelup, location.belowbar, productionColor, text = "FB", textcolor = color.white, size = size.tiny)
plotshape(showProduction and vcp_tight_base and completedBar, "VCP Tight Base", shape.labelup, location.belowbar, productionColor, text = "VCP", textcolor = color.white, size = size.tiny)
plotshape(showProduction and ascending_triangle and completedBar, "Ascending Triangle", shape.labelup, location.belowbar, productionColor, text = "AT", textcolor = color.white, size = size.tiny)
plotshape(showContext and cup_with_handle and completedBar, "Cup With Handle", shape.labeldown, location.abovebar, contextColor, text = "CWH", textcolor = color.white, size = size.tiny)
plotshape(showContext and double_bottom and completedBar, "Double Bottom", shape.labeldown, location.abovebar, contextColor, text = "DB", textcolor = color.white, size = size.tiny)
plotshape(showContext and inverse_head_and_shoulders and completedBar, "Inverse Head And Shoulders", shape.labeldown, location.abovebar, contextColor, text = "IHS", textcolor = color.white, size = size.tiny)
plotshape(showContext and falling_wedge and completedBar, "Falling Wedge", shape.labeldown, location.abovebar, contextColor, text = "FW", textcolor = color.white, size = size.tiny)
plotshape(showContext and rounding_base and completedBar, "Rounding Base", shape.labeldown, location.abovebar, contextColor, text = "RB", textcolor = color.white, size = size.tiny)

var table atlasTable = table.new(position.top_right, 2, 7, frame_color = color.rgb(210, 216, 222), border_width = 1)
if barstate.islast and showTable
    table.cell(atlasTable, 0, 0, "PATTERN ATLAS V5", text_color = color.white, bgcolor = color.rgb(28, 36, 44))
    table.cell(atlasTable, 1, 0, "12 patterns", text_color = color.white, bgcolor = color.rgb(28, 36, 44))
    table.cell(atlasTable, 0, 1, "Selected")
    table.cell(atlasTable, 1, 1, selectedPattern)
    table.cell(atlasTable, 0, 2, "Class")
    table.cell(atlasTable, 1, 2, selectedClass)
    table.cell(atlasTable, 0, 3, "Lifecycle")
    table.cell(atlasTable, 1, 3, lifecycle)
    table.cell(atlasTable, 0, 4, "Trigger")
    table.cell(atlasTable, 1, 4, str.tostring(selectedTrigger, format.mintick))
    table.cell(atlasTable, 0, 5, "Invalidation")
    table.cell(atlasTable, 1, 5, str.tostring(selectedInvalidation, format.mintick))
    table.cell(atlasTable, 0, 6, "Distance ATR")
    table.cell(atlasTable, 1, 6, str.tostring(distanceAtr, "#.00"))

alertcondition(selectedClass == "production" and lifecycle == "Ready" and completedBar, "V5 production pattern ready", "{{ticker}} has a completed-bar production pattern inside the v5 ready distance.")
alertcondition(selectedClass == "context only" and lifecycle == "Ready" and completedBar, "V5 context pattern observed", "{{ticker}} has a context-only bullish pattern. It is not a v5 production entry pattern.")
