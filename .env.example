# Read-only Alpaca market-data credentials. Never use brokerage, account, or order credentials.
ALPACA_API_KEY_ID=
ALPACA_API_SECRET_KEY=
ALPACA_DATA_BASE_URL=https://data.alpaca.markets
ALPACA_METADATA_BASE_URL=https://paper-api.alpaca.markets
ALPACA_FEED=sip
ALPACA_OPTION_FEED=opra
ALPACA_MIN_REQUEST_INTERVAL_SECONDS=0.45
ALPACA_MAX_RETRIES=8
ALPACA_RETRY_BASE_SECONDS=2.0

# Optional: entitled Massive historical-options and earnings research access.
MASSIVE_API_KEY=

# Optional: notification delivery. Leave blank to keep local scans notification-free.
TELEGRAM_BOT_TOKEN=
TELEGRAM_CHAT_ID=
TELEGRAM_BOT_USERNAME=AlisScreenerBot
TELEGRAM_BOT_URL=https://t.me/AlisScreenerBot

# Default persistence is local, untracked JSON state.
STORAGE_BACKEND=local_json
