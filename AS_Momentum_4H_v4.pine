//@version=6
indicator(
    title = "Ali Swing Suite: Bullish Participation Momentum 4H v4",
    shorttitle = "AS Momentum 4H v4",
    overlay = true,
    max_bars_back = 500,
    max_labels_count = 100,
    max_lines_count = 60
)

// config/strategy.yaml parity constants. Do not edit independently.
const int PARITY_SCHEMA_VERSION = 4
const int PARITY_MOMENTUM_MINIMUM = 75

string GROUP_MOMENTUM = "Momentum"
string GROUP_DIVERGENCE = "Divergence"
string GROUP_DISPLAY = "Display"

int rsiLength = input.int(14, "RSI length", minval = 5, group = GROUP_MOMENTUM)
int macdFast = input.int(12, "MACD fast", minval = 2, group = GROUP_MOMENTUM)
int macdSlow = input.int(26, "MACD slow", minval = 3, group = GROUP_MOMENTUM)
int macdSignalLength = input.int(9, "MACD signal", minval = 2, group = GROUP_MOMENTUM)
int divergenceLeft = input.int(5, "Pivot left bars", minval = 2, maxval = 10, group = GROUP_DIVERGENCE)
int divergenceRight = input.int(5, "Pivot right bars", minval = 2, maxval = 10, group = GROUP_DIVERGENCE)
int divergenceInfluence = input.int(10, "Divergence influence bars", minval = 1, maxval = 30, group = GROUP_DIVERGENCE)
bool showReactionLevels = input.bool(true, "Show reaction levels", group = GROUP_DISPLAY)
bool showAverages = input.bool(true, "Show 4H averages", group = GROUP_DISPLAY)
bool tintBars = input.bool(true, "Tint bars by momentum state", group = GROUP_DISPLAY)
bool showTable = input.bool(true, "Show momentum table", group = GROUP_DISPLAY)

f_scoreColor(int value) =>
    value >= PARITY_MOMENTUM_MINIMUM ? color.rgb(20, 125, 79) :
     value >= 60 ? color.rgb(154, 91, 8) :
     color.rgb(161, 57, 57)

float ema21 = ta.ema(close, 21)
float sma50 = ta.sma(close, 50)
float rsiValue = ta.rsi(close, rsiLength)
[macdLine, macdSignal, macdHistogram] = ta.macd(close, macdFast, macdSlow, macdSignalLength)
bool rsiRising = rsiValue > rsiValue[1]
bool macdAboveSignal = macdLine > macdSignal
bool macdAboveZero = macdLine > 0
bool histogramRising = macdHistogram > macdHistogram[1]

[dailyClose, dailyEma21, dailySma50, dailyRsi, dailyMacd, dailyMacdSignal] = request.security(
    syminfo.tickerid,
    "1D",
    [
        close[1],
        ta.ema(close, 21)[1],
        ta.sma(close, 50)[1],
        ta.rsi(close, 14)[1],
        (ta.ema(close, 12) - ta.ema(close, 26))[1],
        ta.ema(ta.ema(close, 12) - ta.ema(close, 26), 9)[1]
    ],
    lookahead = barmerge.lookahead_on
)

bool dailyFilter = dailyClose > dailyEma21 and dailyEma21 > dailySma50 and dailyRsi >= 50 and dailyMacd > dailyMacdSignal

float rsiPivotLow = ta.pivotlow(rsiValue, divergenceLeft, divergenceRight)
float priceAtRsiLow = not na(rsiPivotLow) ? low[divergenceRight] : na
float previousRsiLow = ta.valuewhen(not na(rsiPivotLow), rsiPivotLow, 1)
float previousPriceLow = ta.valuewhen(not na(rsiPivotLow), priceAtRsiLow, 1)
bool positiveDivergence = not na(rsiPivotLow) and priceAtRsiLow < previousPriceLow and rsiPivotLow > previousRsiLow
int positiveDivergenceAge = nz(ta.barssince(positiveDivergence), 10000)
bool positiveDivergenceRecent = positiveDivergenceAge <= divergenceInfluence

float rsiPivotHigh = ta.pivothigh(rsiValue, divergenceLeft, divergenceRight)
float priceAtRsiHigh = not na(rsiPivotHigh) ? high[divergenceRight] : na
float previousRsiHigh = ta.valuewhen(not na(rsiPivotHigh), rsiPivotHigh, 1)
float previousPriceHigh = ta.valuewhen(not na(rsiPivotHigh), priceAtRsiHigh, 1)
bool negativeDivergence = not na(rsiPivotHigh) and priceAtRsiHigh > previousPriceHigh and rsiPivotHigh < previousRsiHigh
int negativeDivergenceAge = nz(ta.barssince(negativeDivergence), 10000)
bool negativeDivergenceRecent = negativeDivergenceAge <= divergenceInfluence

bool warningActive = rsiValue < 50 or not macdAboveSignal or negativeDivergenceRecent
int momentumScore = 0
momentumScore += rsiValue >= 75 ? 20 : rsiValue >= 60 ? 30 : rsiValue >= 50 ? 22 : rsiValue >= 40 ? 10 : 0
momentumScore += rsiRising ? 10 : 0
momentumScore += macdAboveSignal ? 25 : 0
momentumScore += macdAboveZero ? 20 : 0
momentumScore += histogramRising ? 15 : 0
momentumScore += positiveDivergenceRecent ? 5 : 0
momentumScore -= negativeDivergenceRecent ? 5 : 0
momentumScore -= warningActive ? 10 : 0
momentumScore := math.max(0, math.min(momentumScore, 100))
momentumScore := not macdAboveSignal ? math.min(momentumScore, 74) : momentumScore
momentumScore := rsiValue >= 75 ? math.min(momentumScore, 84) : momentumScore

bool bullishConfirmation = rsiValue >= 50 and macdAboveSignal and histogramRising and dailyFilter
string momentumState = warningActive ? "Warning active" :
     rsiValue >= 75 ? "Extended" :
     momentumScore >= 85 and bullishConfirmation ? "Strong bullish" :
     momentumScore >= PARITY_MOMENTUM_MINIMUM and bullishConfirmation ? "Bullish" :
     not dailyFilter ? "Daily blocked" :
     macdAboveSignal or rsiRising ? "Improving" :
     "Neutral"

float trigger = ta.highest(high, 5)
float support = ta.lowest(low, 5)
float warning = math.min(support, ema21)
bool momentumReady = momentumScore >= PARITY_MOMENTUM_MINIMUM and bullishConfirmation
bool signalBarAllowed = barstate.isconfirmed
bool recommendedTimeframe = timeframe.period == "240"
int stateCode = momentumReady ? 3 : momentumState == "Improving" ? 1 : momentumState == "Warning active" ? -1 : 0

plot(showAverages ? ema21 : na, "4H EMA21", color = color.rgb(31, 90, 148), linewidth = 2)
plot(showAverages ? sma50 : na, "4H SMA50", color = color.rgb(180, 105, 20), linewidth = 2)
plot(showReactionLevels ? trigger : na, "4H Trigger", color = color.rgb(20, 125, 79), style = plot.style_linebr)
plot(showReactionLevels ? support : na, "4H Support", color = color.rgb(31, 90, 148), style = plot.style_linebr)
plot(showReactionLevels ? warning : na, "4H Warning", color = color.rgb(161, 57, 57), style = plot.style_linebr)
plotshape(momentumReady and signalBarAllowed, title = "Bullish 4H confirmation", style = shape.triangleup, location = location.belowbar, color = color.rgb(20, 125, 79), size = size.tiny)
plotshape(positiveDivergence and signalBarAllowed, title = "Positive RSI divergence", style = shape.circle, location = location.belowbar, color = color.rgb(31, 90, 148), size = size.tiny)
plotshape(negativeDivergence and signalBarAllowed, title = "Negative RSI divergence warning", style = shape.circle, location = location.abovebar, color = color.rgb(161, 57, 57), size = size.tiny)
barcolor(tintBars ? momentumReady ? color.new(color.rgb(20, 125, 79), 55) : warningActive ? color.new(color.rgb(161, 57, 57), 68) : na : na)

plot(momentumScore, "V4 Momentum Score", display = display.data_window)
plot(rsiValue, "V4 RSI", display = display.data_window)
plot(macdHistogram, "V4 MACD Histogram", display = display.data_window)
plot(dailyFilter ? 1 : 0, "V4 Daily Filter", display = display.data_window)
plot(stateCode, "V4 Momentum State Code", display = display.data_window)

var table momentumTable = table.new(position.top_right, 2, 10, frame_color = color.rgb(216, 222, 229), border_width = 1)
if barstate.islast and showTable
    table.cell(momentumTable, 0, 0, "MOMENTUM V4", text_color = color.white, bgcolor = color.rgb(23, 33, 43))
    table.cell(momentumTable, 1, 0, syminfo.ticker, text_color = color.white, bgcolor = color.rgb(23, 33, 43))
    table.cell(momentumTable, 0, 1, "Timeframe")
    table.cell(momentumTable, 1, 1, recommendedTimeframe ? "4H confirmed" : "Use 4H", text_color = recommendedTimeframe ? color.rgb(20, 125, 79) : color.rgb(154, 91, 8))
    table.cell(momentumTable, 0, 2, "State")
    table.cell(momentumTable, 1, 2, momentumState)
    table.cell(momentumTable, 0, 3, "Score")
    table.cell(momentumTable, 1, 3, str.tostring(momentumScore), text_color = f_scoreColor(momentumScore))
    table.cell(momentumTable, 0, 4, "Daily filter")
    table.cell(momentumTable, 1, 4, dailyFilter ? "Pass" : "Blocked", text_color = dailyFilter ? color.rgb(20, 125, 79) : color.rgb(161, 57, 57))
    table.cell(momentumTable, 0, 5, "RSI")
    table.cell(momentumTable, 1, 5, str.tostring(rsiValue, "#.0"))
    table.cell(momentumTable, 0, 6, "MACD histogram")
    table.cell(momentumTable, 1, 6, str.tostring(macdHistogram, "#.000"))
    table.cell(momentumTable, 0, 7, "Trigger")
    table.cell(momentumTable, 1, 7, str.tostring(trigger, format.mintick))
    table.cell(momentumTable, 0, 8, "Support")
    table.cell(momentumTable, 1, 8, str.tostring(support, format.mintick))
    table.cell(momentumTable, 0, 9, "Warning")
    table.cell(momentumTable, 1, 9, str.tostring(warning, format.mintick))

alertcondition(momentumReady and not momentumReady[1] and signalBarAllowed, "Bullish v4 4H momentum confirmed", "{{ticker}} has confirmed Bullish Participation v4 momentum on the 4H chart.")
alertcondition(close > trigger[1] and close[1] <= trigger[2] and dailyFilter and signalBarAllowed, "Bullish v4 4H trigger", "{{ticker}} closed through its 4H reaction trigger with the daily filter aligned.")
alertcondition(close < warning and close[1] >= warning[1] and signalBarAllowed, "Bullish v4 4H warning", "{{ticker}} closed below its 4H momentum warning level.")
alertcondition(negativeDivergence and signalBarAllowed, "Bullish v4 negative divergence warning", "{{ticker}} formed a confirmed negative RSI divergence on the 4H chart.")
