//@version=6
indicator(
    title = "Ali Swing Suite: Weekly Screener v5",
    shorttitle = "AS Weekly Screener v5",
    overlay = false,
    max_bars_back = 500
)

// config/strategy.yaml parity constants. Do not edit independently.
const int PARITY_SCHEMA_VERSION = 5
const int PARITY_TREND_MINIMUM = 80
const int PARITY_LEADERSHIP_MINIMUM = 70
const int PARITY_SETUP_MINIMUM = 75
const int PARITY_TIMING_MINIMUM = 75
const int PARITY_MARKET_MINIMUM = 70
const float PARITY_READY_DISTANCE_ATR = 0.30
const float PARITY_MAX_EXTENSION_ATR = 0.75
const int PARITY_MAX_CONFIRMED_AGE = 1

string benchmarkSymbol = input.symbol("AMEX:SPY", "Hourly market benchmark")

// Four request calls. Pine Screener allows at most five.
[dClose, dClose1, dClose63, dLow, dEma21, dSma50, dSma200, dSma200Prior, dAtr, dRelVolume, dBreakout, dBaseHigh, dBaseLow, dFlagLow, dFlagPole, dVcp60, dVcp40, dVcp20, dTriangleLowRecent, dTriangleLowPrior, dPullbackTrigger, dFlagTrigger] = request.security(
    syminfo.tickerid,
    "1D",
    [
        close[1],
        close[2],
        close[64],
        low[1],
        ta.ema(close, 21)[1],
        ta.sma(close, 50)[1],
        ta.sma(close, 200)[1],
        ta.sma(close, 200)[11],
        ta.atr(14)[1],
        (volume / math.max(ta.sma(volume, 20), 1))[1],
        ta.highest(high[1], 20)[1],
        ta.highest(high, 25)[1],
        ta.lowest(low, 25)[1],
        ta.lowest(low, 5)[1],
        (close[5] - close[15])[1],
        (ta.highest(high, 60) - ta.lowest(low, 60))[1],
        (ta.highest(high, 40) - ta.lowest(low, 40))[1],
        (ta.highest(high, 20) - ta.lowest(low, 20))[1],
        ta.lowest(low, 15)[1],
        ta.lowest(low[15], 15)[1],
        ta.highest(high, 2)[1],
        ta.highest(high, 5)[1]
    ],
    lookahead = barmerge.lookahead_on
)
[hClose, hLow, hPriorLowestLow, hEma9, hEma21, hVwap, hRsi, hMacdHistogram, hMacdHistogramPrior, hRelVolume] = request.security(
    syminfo.tickerid,
    "60",
    [
        close[1],
        low[1],
        ta.lowest(low[2], 4),
        ta.ema(close, 9)[1],
        ta.ema(close, 21)[1],
        ta.vwap(hlc3)[1],
        ta.rsi(close, 14)[1],
        (ta.ema(close, 12) - ta.ema(close, 26) - ta.ema(ta.ema(close, 12) - ta.ema(close, 26), 9))[1],
        (ta.ema(close, 12) - ta.ema(close, 26) - ta.ema(ta.ema(close, 12) - ta.ema(close, 26), 9))[2],
        (volume / math.max(ta.sma(volume, 20), 1))[1]
    ],
    lookahead = barmerge.lookahead_on
)
[spyClose, spyClose63, spySma50, spySma200] = request.security(
    "AMEX:SPY",
    "1D",
    [close[1], close[64], ta.sma(close, 50)[1], ta.sma(close, 200)[1]],
    lookahead = barmerge.lookahead_on
)
[qqqClose, qqqSma50, qqqSma200] = request.security(
    "NASDAQ:QQQ",
    "1D",
    [close[1], ta.sma(close, 50)[1], ta.sma(close, 200)[1]],
    lookahead = barmerge.lookahead_on
)
[marketHourClose, marketHourEma9, marketHourEma21] = request.security(
    benchmarkSymbol,
    "60",
    [close[1], ta.ema(close, 9)[1], ta.ema(close, 21)[1]],
    lookahead = barmerge.lookahead_on
)

int trendScore = 0
trendScore += dClose > dEma21 ? 15 : 0
trendScore += dEma21 > dSma50 ? 15 : 0
trendScore += dClose > dSma50 ? 10 : 0
trendScore += dSma50 > dSma200 ? 20 : 0
trendScore += dClose > dSma200 ? 15 : 0
trendScore += dSma200 > dSma200Prior ? 10 : 0
trendScore += dClose > dClose63 ? 15 : 0

int marketScore = (spyClose > spySma50 and spySma50 > spySma200 ? 50 : 0) + (qqqClose > qqqSma50 and qqqSma50 > qqqSma200 ? 50 : 0)
bool indexLane = syminfo.ticker == "SPY" or syminfo.ticker == "QQQ"
int leadershipScore = indexLane ? 100 : dClose / math.max(dClose63, syminfo.mintick) >= spyClose / math.max(spyClose63, syminfo.mintick) ? 75 : 50

float support = math.max(math.min(dEma21, dClose), math.min(dSma50, dClose))
bool controlled_pullback = dLow <= support + PARITY_READY_DISTANCE_ATR * dAtr and dClose > support
bool confirmed_breakout = dClose > dBreakout and dClose1 <= dBreakout and dRelVolume >= 1.20
float flagRetracement = dFlagPole > 0 ? (dClose1 - dFlagLow) / dFlagPole : 1.0
bool bull_flag = dFlagPole >= 2.0 * dAtr and flagRetracement >= 0.10 and flagRetracement <= 0.50
float baseDepth = dBaseHigh > 0 ? (dBaseHigh - dBaseLow) / dBaseHigh : 1.0
bool flat_base = baseDepth <= 0.12
bool vcp_tight_base = dVcp40 <= 0.85 * dVcp60 and dVcp20 <= 0.85 * dVcp40
bool ascending_triangle = dTriangleLowRecent > dTriangleLowPrior and dClose >= dBreakout - PARITY_READY_DISTANCE_ATR * dAtr
bool breakout_retest = dClose > dBreakout and dLow <= dBreakout + PARITY_READY_DISTANCE_ATR * dAtr

int patternCode = controlled_pullback ? 1 : confirmed_breakout ? 2 : bull_flag ? 3 : breakout_retest ? 4 : flat_base ? 5 : vcp_tight_base ? 6 : ascending_triangle ? 7 : 0
float trigger = patternCode == 1 ? dPullbackTrigger : patternCode == 3 ? dFlagTrigger : dBreakout
int setupScore = patternCode == 0 ? 0 : confirmed_breakout ? 92 : controlled_pullback or breakout_retest ? 90 : bull_flag ? 88 : vcp_tight_base ? 86 : ascending_triangle ? 85 : 82
float distanceAtr = (trigger - dClose) / math.max(dAtr, syminfo.mintick)
float extensionAtr = math.max(0.0, (dClose - trigger) / math.max(dAtr, syminfo.mintick))
bool lifecyclePass = (distanceAtr >= 0 and distanceAtr <= PARITY_READY_DISTANCE_ATR) or (extensionAtr >= 0 and extensionAtr <= PARITY_MAX_EXTENSION_ATR)

bool higherLow = hLow > hPriorLowestLow
int timingScore = 0
timingScore += hClose > hEma9 and hEma9 > hEma21 ? 20 : hClose > hEma21 ? 10 : 0
timingScore += hClose > hVwap ? 15 : 0
timingScore += hRsi >= 52 and hRsi <= 72 ? 15 : hRsi >= 48 ? 8 : 0
timingScore += hMacdHistogram > 0 and hMacdHistogram >= hMacdHistogramPrior ? 15 : hMacdHistogram > hMacdHistogramPrior ? 8 : 0
timingScore += hRelVolume >= 0.90 ? 10 : 0
timingScore += higherLow ? 10 : 0
timingScore += marketHourClose > marketHourEma9 and marketHourEma9 > marketHourEma21 ? 15 : 0

bool technicalReady = trendScore >= PARITY_TREND_MINIMUM and leadershipScore >= PARITY_LEADERSHIP_MINIMUM and setupScore >= PARITY_SETUP_MINIMUM and timingScore >= PARITY_TIMING_MINIMUM and marketScore >= PARITY_MARKET_MINIMUM and lifecyclePass and extensionAtr <= PARITY_MAX_EXTENSION_ATR
int stateCode = technicalReady ? 2 : trendScore >= 60 and setupScore > 0 ? 1 : 0
int laneCode = indexLane ? 1 : 2

// Keep these as the first ten plots: TradingView Pine Screener exposes them as columns.
plot(stateCode, "State")
plot(patternCode, "Pattern Code")
plot(trendScore, "Trend")
plot(setupScore, "Setup")
plot(timingScore, "Timing")
plot(marketScore, "Market")
plot(distanceAtr, "Distance ATR")
plot(dRelVolume, "Daily Relative Volume")
plot(extensionAtr, "Extension ATR")
plot(laneCode, "Lane")

alertcondition(technicalReady, "V5 screener technical finalist", "{{ticker}} is a v5 technical finalist. Live event, feed, and option verification is still required.")
